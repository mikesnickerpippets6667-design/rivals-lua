sg.IgnoreGuiInset=true; sg.ZIndexBehavior=Enum.ZIndexBehavior.Sibling
pcall(function() sg.Parent=CoreGui end)

-- ═══════════════════════════════════════════
--  UI BUILDER FUNCTIONS
-- ═══════════════════════════════════════════
local function mkCorner(r,p)   local c=Instance.new("UICorner",p); c.CornerRadius=UDim.new(0,r); return c end
local function mkStroke(col,th,p) local s=Instance.new("UIStroke",p); s.Color=col; s.Thickness=th; s.ApplyStrokeMode=Enum.ApplyStrokeMode.Border; return s end
local function mkGrad(c0,c1,rot,p)
    local g=Instance.new("UIGradient",p)
    g.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,c0),ColorSequenceKeypoint.new(1,c1)})
    g.Rotation=rot; return g
end

local function setupList(page)
    local yl=Instance.new("UIListLayout",page)
    yl.Padding=UDim.new(0,4); yl.FillDirection=Enum.FillDirection.Vertical
    yl.SortOrder=Enum.SortOrder.LayoutOrder; yl.HorizontalAlignment=Enum.HorizontalAlignment.Center
    yl.Changed:Connect(function() page.CanvasSize=UDim2.new(0,0,0,yl.AbsoluteContentSize.Y+12) end)
    local pad=Instance.new("UIPadding",page); pad.PaddingTop=UDim.new(0,6)
end

local function mkSecLbl(page,txt,order)
    local f=Instance.new("Frame",page); f.Size=UDim2.new(1,-16,0,22); f.BackgroundTransparency=1; f.LayoutOrder=order
    local l=Instance.new("TextLabel",f); l.Size=UDim2.new(1,0,1,0); l.BackgroundTransparency=1
    l.Text=txt; l.TextColor3=T.Accent; l.Font=Enum.Font.GothamBold; l.TextSize=10; l.TextXAlignment=Enum.TextXAlignment.Left
    return f
end

-- Toggle row — returns (frame, getState, setState)
-- setState(bool) sets the visual AND calls the callback
local function mkToggle(page, label, order, onCb, offCb, color)
    color = color or T.On
    local row=Instance.new("Frame",page); row.Size=UDim2.new(1,-16,0,36); row.BackgroundColor3=T.Surface
    row.BorderSizePixel=0; row.LayoutOrder=order; mkCorner(8,row)
    local lbl=Instance.new("TextLabel",row); lbl.Size=UDim2.new(1,-70,1,0); lbl.Position=UDim2.new(0,12,0,0)
    lbl.BackgroundTransparency=1; lbl.Text=label; lbl.TextColor3=T.Text
    lbl.Font=Enum.Font.GothamMedium; lbl.TextSize=12; lbl.TextXAlignment=Enum.TextXAlignment.Left
    local sw=Instance.new("TextButton",row); sw.Size=UDim2.fromOffset(50,22); sw.Position=UDim2.new(1,-58,0.5,-11)
    sw.BackgroundColor3=T.Off; sw.AutoButtonColor=false; sw.Text=""; mkCorner(11,sw)
    local ball=Instance.new("Frame",sw); ball.Size=UDim2.fromOffset(16,16); ball.Position=UDim2.fromOffset(3,3)
    ball.BackgroundColor3=T.Ball; ball.BorderSizePixel=0; mkCorner(8,ball)
    local state=false
    local function set(s, silent)
        state=s
        TweenService:Create(ball,TweenInfo.new(0.18,Enum.EasingStyle.Quad),{Position=s and UDim2.fromOffset(31,3) or UDim2.fromOffset(3,3)}):Play()
        TweenService:Create(sw,TweenInfo.new(0.18),{BackgroundColor3=s and color or T.Off}):Play()
        if not silent then if s then onCb() else offCb() end end
    end
    sw.MouseButton1Click:Connect(function() set(not state) end)
    sw.TouchTap:Connect(function() set(not state) end)
    return row, function() return state end, set
end

-- Slider row — returns (frame, getValue, setValue)
local function mkSlider(page, label, order, minV, maxV, defV, onChange)
    local row=Instance.new("Frame",page); row.Size=UDim2.new(1,-16,0,44); row.BackgroundColor3=T.Surface
    row.BorderSizePixel=0; row.LayoutOrder=order; mkCorner(8,row)
    local lbl=Instance.new("TextLabel",row); lbl.Size=UDim2.new(1,-10,0,14); lbl.Position=UDim2.new(0,10,0,4)
    lbl.BackgroundTransparency=1; lbl.Text=label..": "..tostring(defV); lbl.TextColor3=T.Sub
    lbl.Font=Enum.Font.Gotham; lbl.TextSize=10; lbl.TextXAlignment=Enum.TextXAlignment.Left
    local track=Instance.new("Frame",row); track.Size=UDim2.new(1,-20,0,6); track.Position=UDim2.new(0,10,0,26)
    track.BackgroundColor3=Color3.fromRGB(28,33,55); track.BorderSizePixel=0; mkCorner(3,track)
    local fill=Instance.new("Frame",track); fill.Size=UDim2.new((defV-minV)/(maxV-minV),0,1,0)
    fill.BackgroundColor3=T.Accent; fill.BorderSizePixel=0; mkCorner(3,fill); mkGrad(T.Accent,T.Accent2,90,fill)
    local dragging,val=false,defV
    local function setVal(v)
        val=math.clamp(v,minV,maxV)
        fill.Size=UDim2.new((val-minV)/(maxV-minV),0,1,0)
        lbl.Text=label..": "..string.format("%.1f",val)
        if onChange then onChange(val) end
    end
    track.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then dragging=true end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then dragging=false end end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
            local abs=track.AbsolutePosition; local sz=track.AbsoluteSize
            setVal(minV+math.clamp((i.Position.X-abs.X)/sz.X,0,1)*(maxV-minV))
        end
    end)
    return row, function() return val end, setVal
end

-- Mode grid — returns (frame, getMode, setMode)
local function mkModeGrid(page, order, modes, defMode, color, onChange)
    local frame=Instance.new("Frame",page); frame.Size=UDim2.new(1,-16,0,0)
    frame.BackgroundTransparency=1; frame.LayoutOrder=order
    local gl=Instance.new("UIGridLayout",frame); gl.CellSize=UDim2.new(0.5,-3,0,28); gl.CellPadding=UDim2.new(0,4,0,4)
    gl.Changed:Connect(function() frame.Size=UDim2.new(1,-16,0,gl.AbsoluteContentSize.Y+4) end)
    local btns={}; local current=defMode
    local function select(m, silent)
        current=m
        for n,b in pairs(btns) do
            TweenService:Create(b,TweenInfo.new(0.15),{BackgroundColor3=n==m and color or T.Surface, TextColor3=n==m and Color3.fromRGB(255,255,255) or T.Sub}):Play()
        end
        if not silent and onChange then onChange(m) end
    end
    for _,m in ipairs(modes) do
        local mb=Instance.new("TextButton",frame); mb.BackgroundColor3=T.Surface; mb.Text=m
        mb.TextColor3=T.Sub; mb.Font=Enum.Font.GothamSemibold; mb.TextSize=10
        mb.AutoButtonColor=false; mb.BorderSizePixel=0; mkCorner(6,mb); btns[m]=mb
        mb.MouseButton1Click:Connect(function() select(m) end)
    end
    select(defMode, true)
    return frame, function() return current end, select
end

-- Info row with live value label
local function mkInfoRow(page, label, order, valColor)
    local row=Instance.new("Frame",page); row.Size=UDim2.new(1,-16,0,30); row.BackgroundColor3=T.Surface
    row.BorderSizePixel=0; row.LayoutOrder=order; mkCorner(8,row)
    local lbl=Instance.new("TextLabel",row); lbl.Size=UDim2.new(0.55,0,1,0); lbl.Position=UDim2.new(0,12,0,0)
    lbl.BackgroundTransparency=1; lbl.Text=label; lbl.TextColor3=T.Sub
    lbl.Font=Enum.Font.Gotham; lbl.TextSize=11; lbl.TextXAlignment=Enum.TextXAlignment.Left
    local val=Instance.new("TextLabel",row); val.Size=UDim2.new(0.42,0,1,0); val.Position=UDim2.new(0.56,0,0,0)
    val.BackgroundTransparency=1; val.Text="--"; val.TextColor3=valColor or T.Text
    val.Font=Enum.Font.GothamBold; val.TextSize=11; val.TextXAlignment=Enum.TextXAlignment.Right
    return row, val
end

-- Action button row
local function mkActionBtn(page, label, order, btnTxt, color, onClick)
    color=color or T.Accent
    local row=Instance.new("Frame",page); row.Size=UDim2.new(1,-16,0,36); row.BackgroundColor3=T.Surface
    row.BorderSizePixel=0; row.LayoutOrder=order; mkCorner(8,row)
    local lbl=Instance.new("TextLabel",row); lbl.Size=UDim2.new(0.48,0,1,0); lbl.Position=UDim2.new(0,12,0,0)
    lbl.BackgroundTransparency=1; lbl.Text=label; lbl.TextColor3=T.Sub
    lbl.Font=Enum.Font.Gotham; lbl.TextSize=11; lbl.TextXAlignment=Enum.TextXAlignment.Left
    local btn=Instance.new("TextButton",row); btn.Size=UDim2.new(0.48,0,0,26); btn.Position=UDim2.new(0.50,0,0.5,-13)
    btn.BackgroundColor3=color; btn.AutoButtonColor=false; btn.Text=btnTxt
    btn.TextColor3=Color3.fromRGB(255,255,255); btn.Font=Enum.Font.GothamBold; btn.TextSize=11
    mkCorner(7,btn)
    local origTxt=btnTxt
    local function flash(feedbackTxt, feedbackColor)
        btn.Text=feedbackTxt or origTxt; btn.BackgroundColor3=feedbackColor or color
        task.delay(2, function()
            if btn and btn.Parent then btn.Text=origTxt; btn.BackgroundColor3=color end
        end)
    end
    btn.MouseButton1Click:Connect(function() if onClick then onClick(btn, flash) end end)
    btn.TouchTap:Connect(function() if onClick then onClick(btn, flash) end end)
    return row, btn, flash
end

