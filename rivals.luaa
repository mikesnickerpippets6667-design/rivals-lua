local ragebotBtn = makeToggleBtn("🔥 RAGEBOT: OFF  [R]", THEME.Rage, 60)
addGlow(ragebotBtn, THEME.Rage)
local ksBtn      = makeToggleBtn("⌨️ KEYSTROKES: OFF", THEME.Secondary, 50)

