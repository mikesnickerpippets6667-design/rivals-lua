local ksTitle = Instance.new("TextLabel")
ksTitle.Size = UDim2.new(1, 0, 0, 20)
ksTitle.BackgroundTransparency = 1
ksTitle.Text = "KEYSTROKES"
ksTitle.TextColor3 = THEME.Primary
ksTitle.Font = Enum.Font.GothamBold
ksTitle.TextSize = 10
ksTitle.Parent = keystrokeUI

local keysContainer = Instance.new("Frame")
keysContainer.Size = UDim2.new(1, -10, 1, -25)
keysContainer.Position = UDim2.fromOffset(5, 22)
keysContainer.BackgroundTransparency = 1
keysContainer.Parent = keystrokeUI

local keyLabels = {}
local keyPositions = {
    W = {0.5, -25, 0, 0},
    A = {0, 5, 0, 35},
    S = {0.5, -25, 0, 35},
    D = {1, -55, 0, 35},
    Space = {0.5, -40, 0, 70},
    Q = {0, 5, 0, 70},
    R = {1, -55, 0, 70}
}

for key, pos in pairs(keyPositions) do
    local label = Instance.new("TextLabel")
    label.Size = UDim2.fromOffset(50, 30)
    label.Position = UDim2.new(pos[1], pos[2], pos[3], pos[4])
    label.BackgroundColor3 = THEME.Surface
    label.Text = key == "Space" and "SPC" or key
    label.TextColor3 = THEME.TextDim
    label.Font = Enum.Font.GothamBold
    label.TextSize = 12
    label.Parent = keysContainer
    addCorner(label, 6)
    keyLabels[key] = label
end

-- Keystroke detection
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    local key = input.KeyCode.Name
    if keyLabels[key] then
        keyLabels[key].BackgroundColor3 = THEME.Primary
        keyLabels[key].TextColor3 = THEME.Background
    end
    if input.KeyCode == Enum.KeyCode.Space and keyLabels["Space"] then
        keyLabels["Space"].BackgroundColor3 = THEME.Primary
        keyLabels["Space"].TextColor3 = THEME.Background
    end
end)

UserInputService.InputEnded:Connect(function(input, gp)
    local key = input.KeyCode.Name
    if keyLabels[key] then
        keyLabels[key].BackgroundColor3 = THEME.Surface
        keyLabels[key].TextColor3 = THEME.TextDim
    end
    if input.KeyCode == Enum.KeyCode.Space and keyLabels["Space"] then
        keyLabels["Space"].BackgroundColor3 = THEME.Surface
        keyLabels["Space"].TextColor3 = THEME.TextDim
    end
end)

