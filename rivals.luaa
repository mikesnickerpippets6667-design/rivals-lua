erraticToggle.BackgroundColor3 = CONFIG.ORBIT_ERRATIC and THEME.Success or THEME.Danger
erraticToggle.Text = CONFIG.ORBIT_ERRATIC and "ON" or "OFF"
erraticToggle.TextColor3 = THEME.Background; erraticToggle.Font = Enum.Font.GothamBold; erraticToggle.TextSize = 11
erraticToggle.Parent = erraticRow; addCorner(erraticToggle, 6)
erraticToggle.MouseButton1Click:Connect(function()
    CONFIG.ORBIT_ERRATIC = not CONFIG.ORBIT_ERRATIC
    erraticLbl.Text = "Orbit Erratic Mode: " .. (CONFIG.ORBIT_ERRATIC and "ON ✅" or "OFF ❌")
    erraticToggle.Text = CONFIG.ORBIT_ERRATIC and "ON" or "OFF"
    erraticToggle.BackgroundColor3 = CONFIG.ORBIT_ERRATIC and THEME.Success or THEME.Danger
end)

