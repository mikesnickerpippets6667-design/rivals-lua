    -- Script list
    local scrollFrame = Instance.new("ScrollingFrame")
    scrollFrame.Size = UDim2.new(1, 0, 1, -45)
    scrollFrame.Position = UDim2.fromOffset(0, 45)
    scrollFrame.BackgroundColor3 = THEME.Surface
    scrollFrame.BorderSizePixel = 0
    scrollFrame.ScrollBarThickness = 6
    scrollFrame.ScrollBarImageColor3 = THEME.Primary
    scrollFrame.Parent = scriptsContent
    addCorner(scrollFrame, 12)
    
    local scriptListLayout = Instance.new("UIListLayout")
    scriptListLayout.Padding = UDim.new(0, 8)
    scriptListLayout.Parent = scrollFrame
    
    -- Populate scripts
    local function populateScripts(filter)
        for _, child in ipairs(scrollFrame:GetChildren()) do
            if child:IsA("Frame") then child:Destroy() end
        end
        
        for _, scriptData in ipairs(ScriptLibrary) do
            if filter == "" or 
                scriptData.name:lower():find(filter:lower()) or 
                scriptData.game:lower():find(filter:lower()) then
                
                local card = Instance.new("Frame")
                card.Size = UDim2.new(1, -10, 0, 70)
                card.BackgroundColor3 = THEME.SurfaceLight
                card.Parent = scrollFrame
                addCorner(card, 10)
                
                local cardStroke = addStroke(card, THEME.Primary, 1)
                cardStroke.Transparency = 0.5
                
                local name = Instance.new("TextLabel")
                name.Size = UDim2.new(1, -80, 0, 22)
                name.Position = UDim2.fromOffset(10, 8)
                name.BackgroundTransparency = 1
                name.Text = scriptData.name
                name.TextColor3 = THEME.Primary
                name.Font = Enum.Font.GothamBold
                name.TextSize = 15
                name.TextXAlignment = Enum.TextXAlignment.Left
                name.Parent = card
                
                local game = Instance.new("TextLabel")
                game.Size = UDim2.new(0.5, -10, 0, 18)
                game.Position = UDim2.fromOffset(10, 32)
                game.BackgroundTransparency = 1
                game.Text = "🎮 " .. scriptData.game
                game.TextColor3 = THEME.Text
                game.Font = Enum.Font.Gotham
                game.TextSize = 11
                game.TextXAlignment = Enum.TextXAlignment.Left
                game.Parent = card
                
                local type = Instance.new("TextLabel")
                type.Size = UDim2.new(0.3, 0, 0, 18)
                type.Position = UDim2.new(0.6, 0, 0, 32)
                type.BackgroundTransparency = 1
                type.Text = scriptData.type == "Keyless" and "✅ " .. scriptData.type or "🔑 " .. scriptData.type
                type.TextColor3 = scriptData.type == "Keyless" and THEME.Success or THEME.Warning
                type.Font = Enum.Font.GothamBold
                type.TextSize = 11
                type.TextXAlignment = Enum.TextXAlignment.Right
                type.Parent = card
                
                local features = Instance.new("TextLabel")
                features.Size = UDim2.new(1, -80, 0, 16)
                features.Position = UDim2.fromOffset(10, 50)
                features.BackgroundTransparency = 1
                features.Text = scriptData.features
                features.TextColor3 = THEME.TextDim
                features.Font = Enum.Font.Gotham
                features.TextSize = 10
                features.TextXAlignment = Enum.TextXAlignment.Left
                features.TextTruncate = Enum.TextTruncate.AtEnd
                features.Parent = card
                
                local execBtn = Instance.new("TextButton")
                execBtn.Size = UDim2.fromOffset(60, 50)
                execBtn.Position = UDim2.new(1, -70, 0.5, -25)
                execBtn.BackgroundColor3 = THEME.Success
                execBtn.Text = "▶"
                execBtn.TextColor3 = THEME.Text
                execBtn.Font = Enum.Font.GothamBlack
                execBtn.TextSize = 20
                execBtn.Parent = card
                addCorner(execBtn, 8)
                
                execBtn.MouseButton1Click:Connect(function()
                    local success, err = pcall(function()
                        local func = loadstring(scriptData.code)
                        if func then func() end
                    end)
                    if not success then
                        warn("Script Error: " .. tostring(err))
                    end
                end)
                
                -- Hover effects
                local function onHover()
                    TweenService:Create(card, TweenInfo.new(0.2), {BackgroundColor3 = THEME.Surface}):Play()
                end
                local function onLeave()
                    TweenService:Create(card, TweenInfo.new(0.2), {BackgroundColor3 = THEME.SurfaceLight}):Play()
                end
                
                card.MouseEnter:Connect(onHover)
                card.MouseLeave:Connect(onLeave)
            end
        end
        
        scrollFrame.CanvasSize = UDim2.new(0, 0, 0, #scrollFrame:GetChildren() * 78)
    end
    
    searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        populateScripts(searchBox.Text)
    end)
    
    populateScripts("")
    
    -- SETTINGS TAB CONTENT
    local settingsContent = Instance.new("Frame")
    settingsContent.Size = UDim2.new(1, 0, 1, 0)
    settingsContent.BackgroundTransparency = 1
    settingsContent.Visible = false
    settingsContent.Parent = content
    
    local settingsLayout = Instance.new("UIListLayout")
    settingsLayout.Padding = UDim.new(0, 12)
    settingsLayout.Parent = settingsContent
    
    -- Voidspam button
    local voidspamBtn = Instance.new("TextButton")
    voidspamBtn.Size = UDim2.new(1, 0, 0, 60)
    voidspamBtn.BackgroundColor3 = THEME.Danger
    voidspamBtn.Text = "🌀 VOIDSPAM: OFF"
    voidspamBtn.TextColor3 = THEME.Text
    voidspamBtn.Font = Enum.Font.GothamBlack
    voidspamBtn.TextSize = 18
    voidspamBtn.Parent = settingsContent
    addCorner(voidspamBtn, 12)
    addGlow(voidspamBtn, THEME.Danger)
    addStroke(voidspamBtn, THEME.Danger, 2)
    
    -- Orbit button
    local orbitBtn = Instance.new("TextButton")
    orbitBtn.Size = UDim2.new(1, 0, 0, 50)
    orbitBtn.BackgroundColor3 = THEME.Warning
    orbitBtn.Text = "🐚 ORBIT: OFF"
    orbitBtn.TextColor3 = THEME.Text
    orbitBtn.Font = Enum.Font.GothamBold
    orbitBtn.TextSize = 16
    orbitBtn.Parent = settingsContent
    addCorner(orbitBtn, 12)
    addStroke(orbitBtn, THEME.Warning, 2)
    
    -- Aimbot button
    local aimbotBtn = Instance.new("TextButton")
    aimbotBtn.Size = UDim2.new(1, 0, 0, 50)
    aimbotBtn.BackgroundColor3 = THEME.Primary
    aimbotBtn.Text = "🎯 AIMBOT: OFF"
    aimbotBtn.TextColor3 = THEME.Text
    aimbotBtn.Font = Enum.Font.GothamBold
    aimbotBtn.TextSize = 16
    aimbotBtn.Parent = settingsContent
    addCorner(aimbotBtn, 12)
    addStroke(aimbotBtn, THEME.Primary, 2)
    
    -- Ragebot button
    local ragebotBtn = Instance.new("TextButton")
    ragebotBtn.Size = UDim2.new(1, 0, 0, 60)
    ragebotBtn.BackgroundColor3 = THEME.Rage
    ragebotBtn.Text = "🔥 RAGEBOT: OFF"
    ragebotBtn.TextColor3 = THEME.Text
    ragebotBtn.Font = Enum.Font.GothamBlack
    ragebotBtn.TextSize = 18
    ragebotBtn.Parent = settingsContent
    addCorner(ragebotBtn, 12)
    addGlow(ragebotBtn, THEME.Rage)
    addStroke(ragebotBtn, THEME.Rage, 2)
    
    -- Keystrokes toggle
    local ksBtn = Instance.new("TextButton")
    ksBtn.Size = UDim2.new(1, 0, 0, 50)
    ksBtn.BackgroundColor3 = THEME.Secondary
    ksBtn.Text = "⌨️ KEYSTROKES: OFF"
    ksBtn.TextColor3 = THEME.Text
    ksBtn.Font = Enum.Font.GothamBold
    ksBtn.TextSize = 16
    ksBtn.Parent = settingsContent
    addCorner(ksBtn, 12)
    addStroke(ksBtn, THEME.Secondary, 2)
    
    -- Status label
    local status = Instance.new("TextLabel")
    status.Size = UDim2.new(1, 0, 0, 30)
    status.BackgroundTransparency = 1
    status.Text = "✅ Ready"
    status.TextColor3 = THEME.Success
    status.Font = Enum.Font.GothamBold
    status.TextSize = 14
    status.Parent = settingsContent
    
    -- Keybinds info
    local keybinds = Instance.new("TextLabel")
    keybinds.Size = UDim2.new(1, 0, 0, 60)
    keybinds.BackgroundTransparency = 1
    keybinds.Text = "KEYBINDS:\nQ = Aimbot Toggle\nR = Ragebot Toggle"
    keybinds.TextColor3 = THEME.TextDim
    keybinds.Font = Enum.Font.Gotham
    keybinds.TextSize = 11
    keybinds.TextWrapped = true
    keybinds.Parent = settingsContent
    
    -- Button connections
    voidspamBtn.MouseButton1Click:Connect(function()
        if voidspamming then
            stopVoidspam()
            voidspamBtn.Text = "🌀 VOIDSPAM: OFF"
            voidspamBtn.BackgroundColor3 = THEME.Danger
            status.Text = "Voidspam Stopped"
            status.TextColor3 = THEME.Danger
        else
            stopOrbit()
            orbitBtn.Text = "🐚 ORBIT: OFF"
            startVoidspam()
            voidspamBtn.Text = "🌀 VOIDSPAM: ON 🔥"
            voidspamBtn.BackgroundColor3 = THEME.Success
            status.Text = "VOIDSPAM ACTIVE - CRAZY MODE"
            status.TextColor3 = THEME.Rage
        end
    end)
    
    orbitBtn.MouseButton1Click:Connect(function()
        if orbiting then
            stopOrbit()
            orbitBtn.Text = "🐚 ORBIT: OFF"
            status.Text = "Orbit Stopped"
        else
            stopVoidspam()
            voidspamBtn.Text = "🌀 VOIDSPAM: OFF"
            voidspamBtn.BackgroundColor3 = THEME.Danger
            startOrbit()
            orbitBtn.Text = "🐚 ORBIT: ON"
            status.Text = "Orbit Active"
        end
    end)
    
    aimbotBtn.MouseButton1Click:Connect(function()
        aimbotActive = not aimbotActive
        ragebotActive = false
        ragebotBtn.Text = "🔥 RAGEBOT: OFF"
        ragebotBtn.BackgroundColor3 = THEME.Rage
        
        if aimbotActive then
            aimbotBtn.Text = "🎯 AIMBOT: ON"
            aimbotBtn.BackgroundColor3 = THEME.Success
            fovCircle.Visible = true
            status.Text = "Aimbot Active"
        else
            aimbotBtn.Text = "🎯 AIMBOT: OFF"
            aimbotBtn.BackgroundColor3 = THEME.Primary
            fovCircle.Visible = false
            status.Text = "Aimbot Off"
        end
    end)
    
    ragebotBtn.MouseButton1Click:Connect(function()
        ragebotActive = not ragebotActive
        aimbotActive = false
        aimbotBtn.Text = "🎯 AIMBOT: OFF"
        aimbotBtn.BackgroundColor3 = THEME.Primary
        
        if ragebotActive then
            ragebotBtn.Text = "🔥 RAGEBOT: ON ⚡"
            ragebotBtn.BackgroundColor3 = THEME.Success
            fovCircle.Visible = true
            status.Text = "RAGEBOT ACTIVE - DESTROY"
            status.TextColor3 = THEME.Rage
        else
            ragebotBtn.Text = "🔥 RAGEBOT: OFF"
            ragebotBtn.BackgroundColor3 = THEME.Rage
            fovCircle.Visible = false
            status.Text = "Ragebot Off"
        end
    end)
    
    ksBtn.MouseButton1Click:Connect(function()
        keystrokeUI.Visible = not keystrokeUI.Visible
        if keystrokeUI.Visible then
            ksBtn.Text = "⌨️ KEYSTROKES: ON"
            ksBtn.BackgroundColor3 = THEME.Success
        else
            ksBtn.Text = "⌨️ KEYSTROKES: OFF"
            ksBtn.BackgroundColor3 = THEME.Secondary
        end
    end)
    
    -- Tab switching
    scriptsTab.MouseButton1Click:Connect(function()
        currentTab = "Scripts"
        scriptsContent.Visible = true
        settingsContent.Visible = false
        scriptsTab.BackgroundColor3 = THEME.Primary
        scriptsTab.TextColor3 = THEME.Background
        settingsTab.BackgroundColor3 = THEME.SurfaceLight
        settingsTab.TextColor3 = THEME.Text
    end)
    
    settingsTab.MouseButton1Click:Connect(function()
        currentTab = "Settings"
        scriptsContent.Visible = false
        settingsContent.Visible = true
        settingsTab.BackgroundColor3 = THEME.Primary
        settingsTab.TextColor3 = THEME.Background
        scriptsTab.BackgroundColor3 = THEME.SurfaceLight
        scriptsTab.TextColor3 = THEME.Text
    end)
    
    makeDraggable(mainUI, header)
end

-- ===== LAUNCH =====
buildMainUI()
