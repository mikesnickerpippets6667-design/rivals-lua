    if cfg.voidActive then
        local r=getRoot()
        if r then local p=r.Position; statusLbl.Text=string.format("VOID  %.0f, %.0f, %.0f",p.X,p.Y,p.Z); statusLbl.TextColor3=T.Danger end
    elseif cfg.orbitActive then statusLbl.Text="ORBITING"; statusLbl.TextColor3=T.On
    else statusLbl.Text="IDLE"; statusLbl.TextColor3=T.Sub end
end)

