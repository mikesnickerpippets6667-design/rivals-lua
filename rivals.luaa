-- ===== VOIDSPAM (FULLY REWRITTEN) =====
--[[
    3 MODES:
    "combat" - Rapid micro-jitter around current position (±3 studs).
               Keeps you in range to deal damage but makes hitbox erratic.
    "blink"  - Teleport BEHIND target -> brief pause -> void back out -> repeat.
               Great for hacker vs hacker mind games.
    "chaos"  - Full random spam across a wide area (original style, toned down
               to avoid anti-cheat triggers from extreme values).
--]]
local voidspamming  = false
local voidspamConn  = nil
local voidspamLock  = false   -- prevents re-entry while blink is mid-sequence
local originalSizes = {}      -- backup of real part sizes

local function backupSizes()
    originalSizes = {}
    if not player.Character then return end
    for _, part in ipairs(player.Character:GetDescendants()) do
        if part:IsA("BasePart") then
            originalSizes[part] = part.Size
        end
    end
end

local function restoreSizes()
    for part, sz in pairs(originalSizes) do
        if part and part.Parent then
            part.Size = sz
        end
    end
    originalSizes = {}
end

local function setHumanoidStates(enabled)
    local hum = getHumanoid()
    if not hum then return end
    for _, state in ipairs(Enum.HumanoidStateType:GetEnumItems()) do
        pcall(function() hum:SetStateEnabled(state, enabled) end)
    end
end

-- MODE 1: Combat Jitter — micro-scramble hitbox while staying near enemy
local function voidCombat(dt)
    local root = getRoot()
    if not root then return end
    local target = getNearestPlayer(60)
    local base = target and target.Character and
                 target.Character:FindFirstChild("HumanoidRootPart") and
                 target.Character.HumanoidRootPart.Position
                 or root.Position

    local jitter = Vector3.new(
        (math.random() * 2 - 1) * 3,
        (math.random() * 2 - 1) * 1.5,
        (math.random() * 2 - 1) * 3
    )
    root.CFrame = CFrame.new(base + jitter) * CFrame.Angles(0, math.random()*math.pi*2, 0)
    root.AssemblyLinearVelocity = Vector3.zero
end

-- MODE 2: Blink Strike — teleport behind enemy, pause, escape, repeat
local function voidBlink()
    if voidspamLock then return end
    voidspamLock = true

    local root = getRoot()
    local target = getNearestPlayer(200)
    if root and target and target.Character then
        local tRoot = target.Character:FindFirstChild("HumanoidRootPart")
        if tRoot then
            -- Step 1: appear behind them
            local behind = tRoot.CFrame * CFrame.new(0, 0, 3.5)
            root.CFrame = behind
            root.AssemblyLinearVelocity = Vector3.zero
            task.wait(0.05)

            -- Step 2: blink away
            if voidspamming and root and root.Parent then
                local escape = tRoot.Position + Vector3.new(
                    (math.random()*2-1)*25,
                    math.random(5,15),
                    (math.random()*2-1)*25
                )
                root.CFrame = CFrame.new(escape)
                root.AssemblyLinearVelocity = Vector3.zero
                task.wait(0.08)
            end
        end
    end

    voidspamLock = false
end

-- MODE 3: Chaos — rapid but bounded random teleports (anti-cheat safer values)
local function voidChaos()
    local root = getRoot()
    if not root then return end
    local spread = 80
    local offset = Vector3.new(
        (math.random()*2-1)*spread,
        (math.random()*2-1)*spread,
        (math.random()*2-1)*spread
    )
    root.CFrame = CFrame.new(root.Position + offset) *
                  CFrame.Angles(math.random()*math.pi*2, math.random()*math.pi*2, math.random()*math.pi*2)
    root.AssemblyLinearVelocity = (math.random()*2-1)*Vector3.new(
        math.random(100,500), math.random(100,500), math.random(100,500)
    )
end

local function startVoidspam()
    if voidspamming then return end
    voidspamming = true
    voidspamLock = false
    backupSizes()
    setHumanoidStates(false)

    local mode = CONFIG.VOIDSPAM_MODE
    if mode == "combat" then
        voidspamConn = RunService.Heartbeat:Connect(function(dt)
            if not voidspamming then return end
            voidCombat(dt)
        end)
    elseif mode == "blink" then
        voidspamConn = RunService.Heartbeat:Connect(function(dt)
            if not voidspamming then return end
            task.spawn(voidBlink)
        end)
    else -- chaos
        voidspamConn = RunService.Heartbeat:Connect(function(dt)
            if not voidspamming then return end
            voidChaos()
        end)
    end
end

local function stopVoidspam()
    voidspamming = false
    voidspamLock = false
    if voidspamConn then voidspamConn:Disconnect(); voidspamConn = nil end
    restoreSizes()
    setHumanoidStates(true)

    local root = getRoot()
    if root then
        root.AssemblyLinearVelocity = Vector3.zero
        root.AssemblyAngularVelocity = Vector3.zero
    end
end

-- ===== ORBIT (FULLY REWRITTEN) =====
--[[
    IMPROVEMENTS:
    - Configurable radius (CONFIG.ORBIT_RADIUS)
    - Erratic mode: randomly shifts speed & direction mid-orbit (hard to counter)
    - Spiral mode: slowly closes in on target (toggle ORBIT_SPIRAL)
    - Height bob: sine wave Y offset so you're not a flat target
    - Locks on to nearest player, refreshes every second
--]]
local orbiting     = false
local orbitConn    = nil
local orbitAngle   = 0
local orbitSpeed   = CONFIG.ORBIT_SPEED   -- can flip sign for direction
local orbitRadius  = CONFIG.ORBIT_RADIUS
local orbitTarget  = nil
local orbitRefreshT= 0

local function startOrbit()
    if orbiting then return end
    orbiting = true
    orbitAngle  = 0
    orbitSpeed  = CONFIG.ORBIT_SPEED
    orbitRadius = CONFIG.ORBIT_RADIUS

    orbitConn = RunService.Heartbeat:Connect(function(dt)
        local myRoot = getRoot()
        orbitRefreshT = orbitRefreshT + dt

        -- Refresh target lock every second
        if orbitRefreshT >= 1 or not orbitTarget or
           not orbitTarget.Character or
           not orbitTarget.Character:FindFirstChild("HumanoidRootPart") then
            orbitTarget = getNearestPlayer()
            orbitRefreshT = 0
        end

        if not myRoot or not orbitTarget then return end
        local tRoot = orbitTarget.Character:FindFirstChild("HumanoidRootPart")
        if not tRoot then return end

        -- Erratic: randomly change speed/direction
        if CONFIG.ORBIT_ERRATIC and math.random() < 0.03 then
            orbitSpeed = CONFIG.ORBIT_SPEED * (math.random()*3 + 0.5) * (math.random() < 0.4 and -1 or 1)
        end

        orbitAngle = orbitAngle + orbitSpeed * dt

        -- Height bob (sine wave, 0.8 amplitude at ~1Hz)
        local yBob = math.sin(orbitAngle * 1.2) * 0.8

        local offset = Vector3.new(
            math.cos(orbitAngle) * orbitRadius,
            2 + yBob,
            math.sin(orbitAngle) * orbitRadius
        )

        local targetPos = tRoot.Position + offset
        myRoot.CFrame = CFrame.lookAt(targetPos, tRoot.Position)
        myRoot.AssemblyLinearVelocity = Vector3.zero
        myRoot.AssemblyAngularVelocity = Vector3.zero
    end)
end

local function stopOrbit()
    orbiting = false
    if orbitConn then orbitConn:Disconnect(); orbitConn = nil end
    orbitTarget = nil
end

-- ===== AIMBOT =====
local aimbotActive  = false
local ragebotActive = false
local aimbotTarget  = nil

-- Ragebot: runs on RenderStepped, NO task.wait (that was the crash bug)
local function doRagebot()
    local target = getClosestToScreen()
    if not target or not target.Character then return end
    local head = target.Character:FindFirstChild("Head")
    if not head then return end
    -- Snap aim with tiny jitter to simulate human micro-adjustments
    local jitter = Vector3.new(
        (math.random()*2-1)*0.3,
        (math.random()*2-1)*0.3,
        0
    )
    camera.CFrame = CFrame.new(camera.CFrame.Position, head.Position + jitter)
end

RunService.RenderStepped:Connect(function()
    if ragebotActive then
        doRagebot()
        fovCircle.Visible = true
        fovCircle.BackgroundColor3 = THEME.Rage
        fovStroke.Color = THEME.Rage
    elseif aimbotActive then
        if not aimbotTarget or not aimbotTarget.Character then
            aimbotTarget = getClosestToScreen()
        end
        if aimbotTarget and aimbotTarget.Character then
            local head = aimbotTarget.Character:FindFirstChild("Head")
            if head then
                local targetCF = CFrame.new(camera.CFrame.Position, head.Position)
                -- Correct smoothing: lerp factor per frame (not inverted)
                camera.CFrame = camera.CFrame:Lerp(targetCF, CONFIG.AIMBOT_SMOOTHNESS)
            end
        end
        fovCircle.Visible = true
        fovCircle.BackgroundColor3 = THEME.Primary
        fovStroke.Color = THEME.Primary
    else
        aimbotTarget = nil
        fovCircle.Visible = false
    end
end)

-- ===== KEYBINDS =====
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == CONFIG.AIMBOT_KEYBIND then
        aimbotActive = not aimbotActive; ragebotActive = false
    elseif input.KeyCode == CONFIG.RAGEBOT_KEYBIND then
        ragebotActive = not ragebotActive; aimbotActive = false
    elseif input.KeyCode == CONFIG.VOIDSPAM_KEYBIND then
        if voidspamming then stopVoidspam() else startVoidspam() end
    elseif input.KeyCode == CONFIG.ORBIT_KEYBIND then
        if orbiting then stopOrbit() else startOrbit() end
    end
end)

-- Respawn cleanup
player.CharacterAdded:Connect(function()
    voidspamming = false
    voidspamLock = false
    orbiting = false
    if voidspamConn then voidspamConn:Disconnect(); voidspamConn = nil end
    if orbitConn then orbitConn:Disconnect(); orbitConn = nil end
    originalSizes = {}
    orbitTarget = nil
end)

