    orbitBtn.BackgroundColor3 = THEME.Warning
    orbitBtn.Text = "🐚 ORBIT: OFF"
    orbitBtn.TextColor3 = THEME.Text
    orbitBtn.Font = Enum.Font.GothamBold
    orbitBtn.TextSize = 16
    orbitBtn.Parent = settingsContent
    addCorner(orbitBtn, 12)
    addStroke(orbitBtn, THEME.Warning, 2)
    
    -- Aimbot button
    local aimbotBtn = Instance.new("TextButton")
    aimbotBtn.Size = UDim2.new(1, 0, 0, 50)
    aimbotBtn.BackgroundColor3 = THEME.Primary
    aimbotBtn.Text = "🎯 AIMBOT: OFF"
    aimbotBtn.TextColor3 = THEME.Text
    aimbotBtn.Font = Enum.Font.GothamBold
    aimbotBtn.TextSize = 16
    aimbotBtn.Parent = settingsContent
    addCorner(aimbotBtn, 12)
    addStroke(aimbotBtn, THEME.Primary, 2)
    
    -- Ragebot button
    local ragebotBtn = Instance.new("TextButton")
    ragebotBtn.Size = UDim2.new(1, 0, 0, 60)
    ragebotBtn.BackgroundColor3 = THEME.Rage
    ragebotBtn.Text = "🔥 RAGEBOT: OFF"
    ragebotBtn.TextColor3 = THEME.Text
    ragebotBtn.Font = Enum.Font.GothamBlack
    ragebotBtn.TextSize = 18
    ragebotBtn.Parent = settingsContent
    addCorner(ragebotBtn, 12)
    addGlow(ragebotBtn, THEME.Rage)
    addStroke(ragebotBtn, THEME.Rage, 2)
    
    -- Keystrokes toggle
    local ksBtn = Instance.new("TextButton")
    ksBtn.Size = UDim2.new(1, 0, 0, 50)
    ksBtn.BackgroundColor3 = THEME.Secondary
    ksBtn.Text = "⌨️ KEYSTROKES: OFF"
    ksBtn.TextColor3 = THEME.Text
    ksBtn.Font = Enum.Font.GothamBold
    ksBtn.TextSize = 16
    ksBtn.Parent = settingsContent
    addCorner(ksBtn, 12)
    addStroke(ksBtn, THEME.Secondary, 2)
    
    -- Status label
    local status = Instance.new("TextLabel")
    status.Size = UDim2.new(1, 0, 0, 30)
    status.BackgroundTransparency = 1
    status.Text = "✅ Ready"
    status.TextColor3 = THEME.Success
    status.Font = Enum.Font.GothamBold
    status.TextSize = 14
    status.Parent = settingsContent
    
    -- Keybinds info
    local keybinds = Instance.new("TextLabel")
    keybinds.Size = UDim2.new(1, 0, 0, 60)
    keybinds.BackgroundTransparency = 1
    keybinds.Text = "KEYBINDS:\nQ = Aimbot Toggle\nR = Ragebot Toggle"
    keybinds.TextColor3 = THEME.TextDim
    keybinds.Font = Enum.Font.Gotham
    keybinds.TextSize = 11
    keybinds.TextWrapped = true
    keybinds.Parent = settingsContent
    
    -- Button connections
    voidspamBtn.MouseButton1Click:Connect(function()
        if voidspamming then
            stopVoidspam()
            voidspamBtn.Text = "🌀 VOIDSPAM: OFF"
            voidspamBtn.BackgroundColor3 = THEME.Danger
            status.Text = "Voidspam Stopped"
            status.TextColor3 = THEME.Danger
        else
            stopOrbit()
            orbitBtn.Text = "🐚 ORBIT: OFF"
            startVoidspam()
            voidspamBtn.Text = "🌀 VOIDSPAM: ON 🔥"
            voidspamBtn.BackgroundColor3 = THEME.Success
            status.Text = "VOIDSPAM ACTIVE - CRAZY MODE"
            status.TextColor3 = THEME.Rage
        end
    end)
    
    orbitBtn.MouseButton1Click:Connect(function()
        if orbiting then
            stopOrbit()
            orbitBtn.Text = "🐚 ORBIT: OFF"
            status.Text = "Orbit Stopped"
        else
            stopVoidspam()
            voidspamBtn.Text = "🌀 VOIDSPAM: OFF"
            voidspamBtn.BackgroundColor3 = THEME.Danger
            startOrbit()
            orbitBtn.Text = "🐚 ORBIT: ON"
            status.Text = "Orbit Active"
        end
    end)
    
    aimbotBtn.MouseButton1Click:Connect(function()
        aimbotActive = not aimbotActive
        ragebotActive = false
        ragebotBtn.Text = "🔥 RAGEBOT: OFF"
        ragebotBtn.BackgroundColor3 = THEME.Rage
        
        if aimbotActive then
            aimbotBtn.Text = "🎯 AIMBOT: ON"
            aimbotBtn.BackgroundColor3 = THEME.Success
            fovCircle.Visible = true
            status.Text = "Aimbot Active"
        else
            aimbotBtn.Text = "🎯 AIMBOT: OFF"
            aimbotBtn.BackgroundColor3 = THEME.Primary
            fovCircle.Visible = false
            status.Text = "Aimbot Off"
        end
    end)
    
    ragebotBtn.MouseButton1Click:Connect(function()
        ragebotActive = not ragebotActive
        aimbotActive = false
        aimbotBtn.Text = "🎯 AIMBOT: OFF"
        aimbotBtn.BackgroundColor3 = THEME.Primary
        
        if ragebotActive then
            ragebotBtn.Text = "🔥 RAGEBOT: ON ⚡"
            ragebotBtn.BackgroundColor3 = THEME.Success
            fovCircle.Visible = true
            status.Text = "RAGEBOT ACTIVE - DESTROY"
            status.TextColor3 = THEME.Rage
        else
            ragebotBtn.Text = "🔥 RAGEBOT: OFF"
            ragebotBtn.BackgroundColor3 = THEME.Rage
            fovCircle.Visible = false
            status.Text = "Ragebot Off"
        end
    end)
    
    ksBtn.MouseButton1Click:Connect(function()
        keystrokeUI.Visible = not keystrokeUI.Visible
        if keystrokeUI.Visible then
            ksBtn.Text = "⌨️ KEYSTROKES: ON"
            ksBtn.BackgroundColor3 = THEME.Success
        else
            ksBtn.Text = "⌨️ KEYSTROKES: OFF"
            ksBtn.BackgroundColor3 = THEME.Secondary
        end
    end)
    
    -- Tab switching
    scriptsTab.MouseButton1Click:Connect(function()
        currentTab = "Scripts"
        scriptsContent.Visible = true
        settingsContent.Visible = false
        scriptsTab.BackgroundColor3 = THEME.Primary
        scriptsTab.TextColor3 = THEME.Background
        settingsTab.BackgroundColor3 = THEME.SurfaceLight
        settingsTab.TextColor3 = THEME.Text
    end)
    
    settingsTab.MouseButton1Click:Connect(function()
        currentTab = "Settings"
        scriptsContent.Visible = false
        settingsContent.Visible = true
        settingsTab.BackgroundColor3 = THEME.Primary
        settingsTab.TextColor3 = THEME.Background
        scriptsTab.BackgroundColor3 = THEME.SurfaceLight
        scriptsTab.TextColor3 = THEME.Text
    end)
    
    makeDraggable(mainUI, header)
end

-- ===== LAUNCH =====
buildMainUI()local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Workspace = game:GetService("Workspace")
local player = Players.LocalPlayer
local camera = Workspace.CurrentCamera

-- Wait for character
if not player.Character then
    player.CharacterAdded:Wait()
end

-- ===== CONFIG =====
local AIMBOT_KEYBIND = Enum.KeyCode.Q
local AIMBOT_SMOOTHNESS = 0.08
local AIMBOT_FOV = 300
local RAGEBOT_KEYBIND = Enum.KeyCode.R

-- ===== PREMIUM THEME =====
local THEME = {
    Background = Color3.fromRGB(5, 5, 8),
    Surface = Color3.fromRGB(15, 15, 22),
    SurfaceLight = Color3.fromRGB(28, 28, 40),
    Primary = Color3.fromRGB(0, 255, 255),
    Secondary = Color3.fromRGB(180, 0, 255),
    Accent = Color3.fromRGB(255, 50, 150),
    Success = Color3.fromRGB(0, 255, 150),
    Danger = Color3.fromRGB(255, 50, 80),
    Warning = Color3.fromRGB(255, 200, 50),
    Gold = Color3.fromRGB(255, 215, 0),
    Text = Color3.fromRGB(255, 255, 255),
    TextDim = Color3.fromRGB(120, 120, 140),
    Rage = Color3.fromRGB(255, 0, 60),
}

-- ===== HELPER FUNCTIONS (DEFINE FIRST) =====
local function addCorner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 12)
    c.Parent = parent
    return c
end

local function addStroke(parent, color, thickness)
    local s = Instance.new("UIStroke")
    s.Color = color or THEME.Primary
    s.Thickness = thickness or 1.5
    s.Transparency = 0.3
    s.Parent = parent
    return s
end

local function addGlow(parent, color)
    local glow = Instance.new("ImageLabel")
    glow.Name = "Glow"
    glow.AnchorPoint = Vector2.new(0.5, 0.5)
    glow.BackgroundTransparency = 1
    glow.Position = UDim2.new(0.5, 0, 0.5, 0)
    glow.Size = UDim2.new(1, 60, 1, 60)
    glow.Image = "rbxassetid://4996890006"
    glow.ImageColor3 = color or THEME.Primary
    glow.ImageTransparency = 0.7
    glow.ZIndex = parent.ZIndex - 1
    glow.Parent = parent
    return glow
end

local function wireButton(btn, baseColor)
    local stroke = btn:FindFirstChildOfClass("UIStroke")
    local originalSize = btn.Size
    
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {
            BackgroundColor3 = baseColor:Lerp(Color3.fromRGB(255,255,255), 0.2),
            Size = UDim2.new(originalSize.X.Scale, originalSize.X.Offset + 6, originalSize.Y.Scale, originalSize.Y.Offset + 6)
        }):Play()
        if stroke then
            TweenService:Create(stroke, TweenInfo.new(0.25), {Transparency = 0, Thickness = 2.5}):Play()
        end
    end)
    
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {
            BackgroundColor3 = baseColor,
            Size = originalSize
        }):Play()
        if stroke then
            TweenService:Create(stroke, TweenInfo.new(0.25), {Transparency = 0.3, Thickness = 1.5}):Play()
        end
    end)
    
    btn.MouseButton1Down:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.1), {
            Size = UDim2.new(originalSize.X.Scale, originalSize.X.Offset - 4, originalSize.Y.Scale, originalSize.Y.Offset - 4)
        }):Play()
    end)
    
    btn.MouseButton1Up:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.1), {
            Size = UDim2.new(originalSize.X.Scale, originalSize.X.Offset + 6, originalSize.Y.Scale, originalSize.Y.Offset + 6)
        }):Play()
    end)
end

local function makeDraggable(frame, dragHandle)
    local dragging = false
    local dragStart, startPos
    
    dragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = Vector2.new(input.Position.X, input.Position.Y)
            startPos = frame.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local currentPos = Vector2.new(input.Position.X, input.Position.Y)
            local delta = currentPos - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
end

-- ScreenGui
