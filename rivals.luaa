-- ║        Brays Lua  v5.0  — RIVALS        ║
-- ║   Void | Defense | Anti-Aim | Config    ║
-- ╚══════════════════════════════════════════╝
local Players          = game:GetService("Players")
local RunService       = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService     = game:GetService("TweenService")
local CoreGui          = game:GetService("CoreGui")
local HttpService      = game:GetService("HttpService")
local player           = Players.LocalPlayer
local cam              = workspace.CurrentCamera

-- ═══════════════════════════════════════════
--  THEME
-- ═══════════════════════════════════════════
local T = {
    BG      = Color3.fromRGB(10,  12,  20),
    Surface = Color3.fromRGB(18,  22,  38),
    Accent  = Color3.fromRGB(0,   180, 255),
    Accent2 = Color3.fromRGB(80,  0,   255),
    On      = Color3.fromRGB(0,   220, 120),
    Off     = Color3.fromRGB(40,  48,  70),
    Danger  = Color3.fromRGB(255, 50,  80),
    AA      = Color3.fromRGB(200, 100, 255),
    Cfg     = Color3.fromRGB(180, 140, 255),
    Text    = Color3.fromRGB(220, 228, 255),
    Sub     = Color3.fromRGB(110, 120, 160),
    Ball    = Color3.fromRGB(240, 245, 255),
    Stroke  = Color3.fromRGB(0,   140, 220),
    AxisX   = Color3.fromRGB(255, 80,  100),
    AxisY   = Color3.fromRGB(100, 230, 140),
    AxisZ   = Color3.fromRGB(80,  160, 255),
    Discord = Color3.fromRGB(88,  101, 242),
}

-- ═══════════════════════════════════════════
--  CENTRAL CONFIG  (single source of truth)
-- ═══════════════════════════════════════════
local cfg = {
    -- Void
    voidActive   = false,
    orbitActive  = false,
    -- Defense
    ghostStep    = false,
    ghostInt     = 7,
    offsetInt    = 0,
    velClamp     = false,
    predBreaker  = false,
    predInt      = 0,
    frameNoise   = false,
    noiseAmt     = 0,
    srcShield    = false,
    -- Anti-Aim
    aaEnabled    = false,
    aaMode       = "SPIN",
    spinSpeed    = 10,
    partMerge    = false,
}
local CONFIG_FILE = "brays_v5.json"

-- ═══════════════════════════════════════════
--  HELPERS
-- ═══════════════════════════════════════════
local function getRoot() local c=player.Character; return c and c:FindFirstChild("HumanoidRootPart") end
local function getHum()  local c=player.Character; return c and c:FindFirstChildOfClass("Humanoid") end
local function getChar() return player.Character end

-- ═══════════════════════════════════════════
--  VOIDSPAM
-- ═══════════════════════════════════════════
local voidConn, shakeConn, bv, bf = nil,nil,nil,nil
local CLIM = 999999999
local VLIM = 99999999

local function destroyPhysics()
    pcall(function() if bv then bv:Destroy(); bv=nil end end)
    pcall(function() if bf then bf:Destroy(); bf=nil end end)
end

local function injectPhysics(root)
    destroyPhysics()
    bv=Instance.new("BodyVelocity"); bv.MaxForce=Vector3.new(math.huge,math.huge,math.huge); bv.Velocity=Vector3.zero; bv.P=9999999; bv.Parent=root
    bf=Instance.new("BodyForce");   bf.Force=Vector3.new(0,99999999,0); bf.Parent=root
end

local function breakChar(root)
    local hum=getHum()
    if hum then
        for _,s in ipairs(Enum.HumanoidStateType:GetEnumItems()) do pcall(function() hum:SetStateEnabled(s,false) end) end
        hum.AutoRotate=false; hum.PlatformStand=true
    end
    local c=getChar()
    if c then for _,p in ipairs(c:GetDescendants()) do if p:IsA("BasePart") then pcall(function() p.CanCollide=false; p.CanTouch=false; p.Massless=true end) end end end
    pcall(function() workspace.FallenPartsDestroyHeight=-CLIM end)
end

local function restoreChar()
    local hum=getHum()
    if hum then
        for _,s in ipairs(Enum.HumanoidStateType:GetEnumItems()) do pcall(function() hum:SetStateEnabled(s,true) end) end
        hum.AutoRotate=true; hum.PlatformStand=false; hum.Health=hum.MaxHealth
    end
    local c=getChar()
    if c then for _,p in ipairs(c:GetDescendants()) do if p:IsA("BasePart") then pcall(function() p.CanCollide=true; p.CanTouch=true; p.Massless=false end) end end end
    destroyPhysics()
    pcall(function() workspace.FallenPartsDestroyHeight=-5000 end)
end

local function voidTick()
    pcall(function()
        local root=getRoot(); local hum=getHum()
        if not root then return end
        root.CFrame=CFrame.new(math.random(-CLIM,CLIM),math.random(-CLIM,CLIM),math.random(-CLIM,CLIM))
        local vx,vy,vz=math.random(-VLIM,VLIM),math.random(-VLIM,VLIM),math.random(-VLIM,VLIM)
        root.AssemblyLinearVelocity=Vector3.new(vx,vy,vz)
        root.AssemblyAngularVelocity=Vector3.new(math.random(-9999,9999),math.random(-9999,9999),math.random(-9999,9999))
        if bv then bv.Velocity=Vector3.new(vx,vy,vz) end
        local c=getChar()
        if c then
            for _,p in ipairs(c:GetDescendants()) do
                if p:IsA("BasePart") and p~=root then
                    pcall(function()
                        p.CFrame=root.CFrame*CFrame.new(math.random(-500,500),math.random(-500,500),math.random(-500,500))
                        p.AssemblyLinearVelocity=Vector3.new(math.random(-VLIM,VLIM),math.random(-VLIM,VLIM),math.random(-VLIM,VLIM))
                    end)
                end
            end
        end
        if hum then hum.Health=hum.MaxHealth end
    end)
end

local function startVoid()
    if cfg.voidActive then return end
    cfg.voidActive=true
    local root=getRoot()
    if root then injectPhysics(root); breakChar(root) end
    shakeConn=RunService.RenderStepped:Connect(function()
        if not cfg.voidActive then return end
        cam.CFrame=cam.CFrame*CFrame.Angles(math.rad(math.random(-15,15)),math.rad(math.random(-15,15)),math.rad(math.random(-15,15)))
    end)
    voidConn=RunService.Heartbeat:Connect(voidTick)
end

local function stopVoid()
    if not cfg.voidActive then return end
    cfg.voidActive=false
    if voidConn  then voidConn:Disconnect();  voidConn=nil end
    if shakeConn then shakeConn:Disconnect(); shakeConn=nil end
    restoreChar()
end

-- ═══════════════════════════════════════════
--  ORBIT
-- ═══════════════════════════════════════════
local orbitConn=nil; local orbitAngle=0

local function getNearestPlayer()
    local root=getRoot(); if not root then return nil end
    local best,bestD=nil,math.huge
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=player and p.Character then
            local r=p.Character:FindFirstChild("HumanoidRootPart")
            local h=p.Character:FindFirstChildOfClass("Humanoid")
            if r and h and h.Health>0 then
                local d=(r.Position-root.Position).Magnitude
                if d<bestD then bestD=d; best=p end
            end
        end
    end
    return best
end

local function startOrbit()
    if cfg.orbitActive then return end
    cfg.orbitActive=true
    orbitConn=RunService.Heartbeat:Connect(function(dt)
        local root=getRoot(); local tgt=getNearestPlayer()
        if not root or not tgt or not tgt.Character then return end
        local tr=tgt.Character:FindFirstChild("HumanoidRootPart"); if not tr then return end
        orbitAngle=orbitAngle+25*dt
        local offset=Vector3.new(math.cos(orbitAngle)*6,1.5,math.sin(orbitAngle)*6)
        root.CFrame=CFrame.lookAt(tr.Position+offset,tr.Position)
        root.AssemblyLinearVelocity=Vector3.zero
    end)
end

local function stopOrbit()
    cfg.orbitActive=false
    if orbitConn then orbitConn:Disconnect(); orbitConn=nil end
end

