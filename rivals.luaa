-- ===== CRAZY VOIDSPAM =====
local voidspamming = false
local voidspamConn = nil
local bodyVel = nil
local bodyGyro = nil
local screenShakeConn = nil

local function getRoot()
    local char = player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart")
end

local function getHumanoid()
    local char = player.Character
    if not char then return nil end
    return char:FindFirstChild("Humanoid")
end

local function createBodyVelocity()
    if bodyVel then bodyVel:Destroy() end
    if bodyGyro then bodyGyro:Destroy() end
    local root = getRoot()
    if not root then return end
    
    bodyVel = Instance.new("BodyVelocity")
    bodyVel.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bodyVel.Velocity = Vector3.zero
    bodyVel.P = 999999
    bodyVel.Parent = root
    
    bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    bodyGyro.P = 999999
    bodyGyro.Parent = root
end

local function destroyBodyVelocity()
    if bodyVel then
        bodyVel:Destroy()
        bodyVel = nil
    end
    if bodyGyro then
        bodyGyro:Destroy()
        bodyGyro = nil
    end
end

-- Screen shake effect
local function startScreenShake()
    screenShakeConn = RunService.RenderStepped:Connect(function()
        if not voidspamming then return end
        camera.CFrame = camera.CFrame * CFrame.new(
            math.random(-5, 5) / 10,
            math.random(-5, 5) / 10,
            math.random(-5, 5) / 10
        ) * CFrame.Angles(
            math.rad(math.random(-3, 3)),
            math.rad(math.random(-3, 3)),
            math.rad(math.random(-3, 3))
        )
    end)
end

local function stopScreenShake()
    if screenShakeConn then
        screenShakeConn:Disconnect()
        screenShakeConn = nil
    end
end

local function doCrazyVoidspam()
    local root = getRoot()
    local humanoid = getHumanoid()
    if not root or not humanoid then return end
    
    -- Disable all states
    for _, state in ipairs(Enum.HumanoidStateType:GetEnumItems()) do
        humanoid:SetStateEnabled(state, false)
    end
    
    -- Extreme random position
    local crazyOffset = Vector3.new(
        math.random(-999999, 999999),
        math.random(-999999, 999999),
        math.random(-999999, 999999)
    )
    root.CFrame = root.CFrame + crazyOffset
    
    -- Extreme velocity
    root.AssemblyLinearVelocity = Vector3.new(
        math.random(-9999999, 9999999),
        math.random(-9999999, 9999999),
        math.random(-9999999, 9999999)
    )
    
    -- Crazy rotation
    root.AssemblyAngularVelocity = Vector3.new(
        math.random(-999999, 999999),
        math.random(-999999, 999999),
        math.random(-999999, 999999)
    )
    
    -- Random orientation
    root.CFrame = CFrame.new(root.Position) * CFrame.Angles(
        math.random(-100000, 100000),
        math.random(-100000, 100000),
        math.random(-100000, 100000)
    )
    
    if bodyVel then
        bodyVel.Velocity = Vector3.new(
            math.random(-999999, 999999),
            math.random(-999999, 999999),
            math.random(-999999, 999999)
        )
    end
    
    if bodyGyro then
        bodyGyro.CFrame = CFrame.Angles(
            math.random(-100000, 100000),
            math.random(-100000, 100000),
            math.random(-100000, 100000)
        )
    end
    
    -- Random size changes
    for _, part in ipairs(player.Character:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            part.Size = Vector3.new(
                math.random(0.1, 10),
                math.random(0.1, 10),
                math.random(0.1, 10)
            )
        end
    end
end

local function startVoidspam()
    if voidspamming then return end
    voidspamming = true
    createBodyVelocity()
    startScreenShake()
    
    voidspamConn = RunService.Heartbeat:Connect(function()
        if not voidspamming then return end
        doCrazyVoidspam()
    end)
end

local function stopVoidspam()
    voidspamming = false
    if voidspamConn then
        voidspamConn:Disconnect()
        voidspamConn = nil
    end
    stopScreenShake()
    destroyBodyVelocity()
    
    local root = getRoot()
    if root then
        root.AssemblyLinearVelocity = Vector3.zero
        root.AssemblyAngularVelocity = Vector3.zero
    end
    
    -- Reset sizes
    for _, part in ipairs(player.Character:GetDescendants()) do
        if part:IsA("BasePart") then
            if part.Name == "Head" then
                part.Size = Vector3.new(2, 1, 1)
            elseif part.Name == "Torso" or part.Name == "UpperTorso" then
                part.Size = Vector3.new(2, 2, 1)
            elseif part.Name == "Left Arm" or part.Name == "Right Arm" or part.Name == "LeftUpperArm" or part.Name == "RightUpperArm" then
                part.Size = Vector3.new(1, 2, 1)
            elseif part.Name == "Left Leg" or part.Name == "Right Leg" or part.Name == "LeftUpperLeg" or part.Name == "RightUpperLeg" then
                part.Size = Vector3.new(1, 2, 1)
            elseif part.Name == "HumanoidRootPart" then
                part.Size = Vector3.new(2, 2, 1)
            end
        end
    end
    
    local humanoid = getHumanoid()
    if humanoid then
        for _, state in ipairs(Enum.HumanoidStateType:GetEnumItems()) do
            humanoid:SetStateEnabled(state, true)
        end
    end
end

-- ===== ORBIT =====
local orbiting = false
local orbitConn = nil
local orbitAngle = 0

local function getNearestRoot()
    local myRoot = getRoot()
    if not myRoot then return nil end
    local closest, dist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local theirRoot = p.Character:FindFirstChild("HumanoidRootPart")
            if theirRoot then
                local d = (theirRoot.Position - myRoot.Position).Magnitude
                if d < dist then
                    dist = d
                    closest = theirRoot
                end
            end
        end
    end
    return closest
end

local function startOrbit()
    if orbiting then return end
    orbiting = true
    orbitConn = RunService.Heartbeat:Connect(function(dt)
        local myRoot = getRoot()
        local target = getNearestRoot()
        if not myRoot or not target then return end
        orbitAngle = orbitAngle + 20 * dt
        local offset = Vector3.new(math.cos(orbitAngle) * 6, 2, math.sin(orbitAngle) * 6)
        myRoot.CFrame = CFrame.lookAt(target.Position + offset, target.Position)
        myRoot.AssemblyLinearVelocity = Vector3.zero
    end)
end

local function stopOrbit()
    orbiting = false
    if orbitConn then
        orbitConn:Disconnect()
        orbitConn = nil
    end
end

-- ===== AIMBOT & RAGEBOT =====
local aimbotActive = false
local ragebotActive = false
local aimbotTarget = nil

local function getClosestPlayer()
    local closest, shortest = nil, AIMBOT_FOV
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local head = p.Character:FindFirstChild("Head")
            local humanoid = p.Character:FindFirstChild("Humanoid")
            if head and humanoid and humanoid.Health > 0 then
                local pos, onScreen = camera:WorldToViewportPoint(head.Position)
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - UserInputService:GetMouseLocation()).Magnitude
                    if dist < shortest then
                        shortest = dist
                        closest = p
                    end
                end
            end
        end
    end
    return closest
end

-- Ragebot features
local function ragebotFeatures()
    if not ragebotActive then return end
    
    local target = getClosestPlayer()
    if target and target.Character then
        local head = target.Character:FindFirstChild("Head")
        if head then
            -- Instant snap
            camera.CFrame = CFrame.new(camera.CFrame.Position, head.Position)
            
            -- Rapid fire aim jitter
            for i = 1, 5 do
                camera.CFrame = CFrame.new(camera.CFrame.Position, head.Position + Vector3.new(math.random(-1,1), math.random(-1,1), math.random(-1,1)))
                task.wait(0.01)
            end
        end
    end
end

RunService.RenderStepped:Connect(function()
    if ragebotActive then
        ragebotFeatures()
        fovCircle.Visible = true
        fovCircle.BackgroundColor3 = THEME.Rage
        fovStroke.Color = THEME.Rage
    elseif aimbotActive then
        if not aimbotTarget or not aimbotTarget.Character then
            aimbotTarget = getClosestPlayer()
        end
        if aimbotTarget and aimbotTarget.Character then
            local head = aimbotTarget.Character:FindFirstChild("Head")
            if head then
                local targetCF = CFrame.new(camera.CFrame.Position, head.Position)
                camera.CFrame = camera.CFrame:Lerp(targetCF, 1 - AIMBOT_SMOOTHNESS)
            end
        end
        fovCircle.Visible = true
        fovCircle.BackgroundColor3 = Color3.fromRGB(0, 255, 255)
        fovStroke.Color = THEME.Primary
    else
        aimbotTarget = nil
        fovCircle.Visible = false
    end
end)

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == AIMBOT_KEYBIND then
        aimbotActive = not aimbotActive
        ragebotActive = false
    elseif input.KeyCode == RAGEBOT_KEYBIND then
        ragebotActive = not ragebotActive
        aimbotActive = false
    end
end)

-- ===== MAIN UI WITH TABS =====
local mainUI = nil
local currentTab = "Scripts"

local function buildMainUI()
    if mainUI then mainUI:Destroy() end
    
    mainUI = Instance.new("Frame")
    mainUI.Size = UDim2.fromOffset(500, 650)
    mainUI.Position = UDim2.new(0.5, -250, 0.5, -325)
    mainUI.BackgroundColor3 = THEME.Background
    mainUI.BorderSizePixel = 0
    mainUI.Parent = screenGui
    addCorner(mainUI, 20)
    addStroke(mainUI, THEME.Primary, 2)
    
    -- Glow
    local glow = addGlow(mainUI, THEME.Primary)
    
    -- Header with gradient animation
