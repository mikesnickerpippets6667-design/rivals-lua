    -- Populate scripts
    local function populateScripts(filter)
        for _, child in ipairs(scrollFrame:GetChildren()) do
            if child:IsA("Frame") then child:Destroy() end
        end
        
        for _, scriptData in ipairs(ScriptLibrary) do
            if filter == "" or 
                scriptData.name:lower():find(filter:lower()) or 
                scriptData.game:lower():find(filter:lower()) then
                
                local card = Instance.new("Frame")
                card.Size = UDim2.new(1, -10, 0, 70)
                card.BackgroundColor3 = THEME.SurfaceLight
                card.Parent = scrollFrame
                addCorner(card, 10)
                
                local cardStroke = addStroke(card, THEME.Primary, 1)
                cardStroke.Transparency = 0.5
                
                local name = Instance.new("TextLabel")
                name.Size = UDim2.new(1, -80, 0, 22)
                name.Position = UDim2.fromOffset(10, 8)
                name.BackgroundTransparency = 1
                name.Text = scriptData.name
                name.TextColor3 = THEME.Primary
                name.Font = Enum.Font.GothamBold
                name.TextSize = 15
                name.TextXAlignment = Enum.TextXAlignment.Left
                name.Parent = card
                
                local game = Instance.new("TextLabel")
                game.Size = UDim2.new(0.5, -10, 0, 18)
                game.Position = UDim2.fromOffset(10, 32)
                game.BackgroundTransparency = 1
                game.Text = "🎮 " .. scriptData.game
                game.TextColor3 = THEME.Text
                game.Font = Enum.Font.Gotham
                game.TextSize = 11
                game.TextXAlignment = Enum.TextXAlignment.Left
                game.Parent = card
                
                local type = Instance.new("TextLabel")
                type.Size = UDim2.new(0.3, 0, 0, 18)
                type.Position = UDim2.new(0.6, 0, 0, 32)
                type.BackgroundTransparency = 1
                type.Text = scriptData.type == "Keyless" and "✅ " .. scriptData.type or "🔑 " .. scriptData.type
                type.TextColor3 = scriptData.type == "Keyless" and THEME.Success or THEME.Warning
                type.Font = Enum.Font.GothamBold
                type.TextSize = 11
                type.TextXAlignment = Enum.TextXAlignment.Right
                type.Parent = card
                
                local features = Instance.new("TextLabel")
                features.Size = UDim2.new(1, -80, 0, 16)
                features.Position = UDim2.fromOffset(10, 50)
                features.BackgroundTransparency = 1
                features.Text = scriptData.features
                features.TextColor3 = THEME.TextDim
                features.Font = Enum.Font.Gotham
                features.TextSize = 10
                features.TextXAlignment = Enum.TextXAlignment.Left
                features.TextTruncate = Enum.TextTruncate.AtEnd
                features.Parent = card
                
                local execBtn = Instance.new("TextButton")
                execBtn.Size = UDim2.fromOffset(60, 50)
                execBtn.Position = UDim2.new(1, -70, 0.5, -25)
                execBtn.BackgroundColor3 = THEME.Success
                execBtn.Text = "▶"
                execBtn.TextColor3 = THEME.Text
                execBtn.Font = Enum.Font.GothamBlack
                execBtn.TextSize = 20
                execBtn.Parent = card
                addCorner(execBtn, 8)
                
                execBtn.MouseButton1Click:Connect(function()
                    local success, err = pcall(function()
                        local func = loadstring(scriptData.code)
                        if func then func() end
                    end)
                    if not success then
                        warn("Script Error: " .. tostring(err))
                    end
                end)
                
                -- Hover effects
                local function onHover()
                    TweenService:Create(card, TweenInfo.new(0.2), {BackgroundColor3 = THEME.Surface}):Play()
                end
                local function onLeave()
                    TweenService:Create(card, TweenInfo.new(0.2), {BackgroundColor3 = THEME.SurfaceLight}):Play()
                end
                
                card.MouseEnter:Connect(onHover)
                card.MouseLeave:Connect(onLeave)
            end
        end
        
        scrollFrame.CanvasSize = UDim2.new(0, 0, 0, #scrollFrame:GetChildren() * 78)
    end
    
    searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        populateScripts(searchBox.Text)
    end)
    
    populateScripts("")
    
    -- SETTINGS TAB CONTENT
