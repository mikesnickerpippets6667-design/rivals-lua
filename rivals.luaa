local mainUI = nil
local currentTab = "Scripts"

local function buildMainUI()
    if mainUI then mainUI:Destroy() end
    
    mainUI = Instance.new("Frame")
    mainUI.Size = UDim2.fromOffset(500, 650)
    mainUI.Position = UDim2.new(0.5, -250, 0.5, -325)
    mainUI.BackgroundColor3 = THEME.Background
    mainUI.BorderSizePixel = 0
    mainUI.Parent = screenGui
    addCorner(mainUI, 20)
    addStroke(mainUI, THEME.Primary, 2)
    
    -- Glow
    local glow = addGlow(mainUI, THEME.Primary)
    
    -- Header with gradient animation
    local header = Instance.new("Frame")
    header.Size = UDim2.new(1, 0, 0, 100)
    header.BackgroundColor3 = THEME.Surface
    header.BorderSizePixel = 0
    header.Parent = mainUI
    addCorner(header, 20)
    
    local headerGradient = Instance.new("UIGradient")
    headerGradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, THEME.Primary),
        ColorSequenceKeypoint.new(0.5, THEME.Secondary),
        ColorSequenceKeypoint.new(1, THEME.Accent)
    })
    headerGradient.Rotation = 0
    headerGradient.Parent = header
    
    -- Animate gradient
    task.spawn(function()
        while mainUI and mainUI.Parent do
            TweenService:Create(headerGradient, TweenInfo.new(2, Enum.EasingStyle.Linear), {
                Rotation = headerGradient.Rotation + 180
            }):Play()
            task.wait(2)
        end
    end)
    
    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, -100, 0, 40)
    title.Position = UDim2.fromOffset(20, 10)
    title.BackgroundTransparency = 1
    title.Text = "⚡ VOID ULTIMATE"
    title.TextColor3 = THEME.Text
    title.Font = Enum.Font.GothamBlack
    title.TextSize = 28
    title.Parent = header
    
    local subtitle = Instance.new("TextLabel")
    subtitle.Size = UDim2.new(1, -100, 0, 20)
    subtitle.Position = UDim2.fromOffset(20, 50)
    subtitle.BackgroundTransparency = 1
