kbInfo.TextWrapped = true; kbInfo.Parent = settingsPanel

-- Button logic
local function setStatus(txt, color)
    statusLabel.Text = txt
    statusLabel.TextColor3 = color or THEME.Success
end

voidBtn.MouseButton1Click:Connect(function()
    if voidspamming then
        stopVoidspam()
        voidBtn.Text = "🌀 VOIDSPAM: OFF  [V]"
        voidBtn.BackgroundColor3 = THEME.Danger
        setStatus("Voidspam stopped", THEME.Danger)
    else
        stopOrbit(); orbitBtn.Text = "🐚 ORBIT: OFF  [O]"; orbitBtn.BackgroundColor3 = THEME.Warning
        startVoidspam()
        voidBtn.Text = "🌀 VOIDSPAM: ON 🔥  [V]"
        voidBtn.BackgroundColor3 = THEME.Success
        setStatus("VOIDSPAM ACTIVE — Mode: "..CONFIG.VOIDSPAM_MODE:upper(), THEME.Rage)
    end
end)

orbitBtn.MouseButton1Click:Connect(function()
    if orbiting then
        stopOrbit()
        orbitBtn.Text = "🐚 ORBIT: OFF  [O]"
        orbitBtn.BackgroundColor3 = THEME.Warning
        setStatus("Orbit stopped", THEME.Warning)
    else
        stopVoidspam(); voidBtn.Text = "🌀 VOIDSPAM: OFF  [V]"; voidBtn.BackgroundColor3 = THEME.Danger
        startOrbit()
        orbitBtn.Text = "🐚 ORBIT: ON 🌀  [O]"
        orbitBtn.BackgroundColor3 = THEME.Success
        setStatus("Orbit active — Erratic: "..(CONFIG.ORBIT_ERRATIC and "ON" or "OFF"), THEME.Success)
    end
end)

aimbotBtn.MouseButton1Click:Connect(function()
    aimbotActive = not aimbotActive; ragebotActive = false
    ragebotBtn.Text = "🔥 RAGEBOT: OFF  [R]"; ragebotBtn.BackgroundColor3 = THEME.Rage
    if aimbotActive then
        aimbotBtn.Text = "🎯 AIMBOT: ON ✅  [Q]"; aimbotBtn.BackgroundColor3 = THEME.Success
        fovCircle.Visible = true; setStatus("Aimbot active", THEME.Primary)
    else
        aimbotBtn.Text = "🎯 AIMBOT: OFF  [Q]"; aimbotBtn.BackgroundColor3 = THEME.Primary
        fovCircle.Visible = false; setStatus("Aimbot off", THEME.TextDim)
    end
end)

ragebotBtn.MouseButton1Click:Connect(function()
    ragebotActive = not ragebotActive; aimbotActive = false
    aimbotBtn.Text = "🎯 AIMBOT: OFF  [Q]"; aimbotBtn.BackgroundColor3 = THEME.Primary
    if ragebotActive then
        ragebotBtn.Text = "🔥 RAGEBOT: ON ⚡  [R]"; ragebotBtn.BackgroundColor3 = THEME.Success
        fovCircle.Visible = true; setStatus("RAGEBOT ACTIVE — destroy mode", THEME.Rage)
    else
        ragebotBtn.Text = "🔥 RAGEBOT: OFF  [R]"; ragebotBtn.BackgroundColor3 = THEME.Rage
        fovCircle.Visible = false; setStatus("Ragebot off", THEME.TextDim)
    end
end)

ksBtn.MouseButton1Click:Connect(function()
    keystrokeUI.Visible = not keystrokeUI.Visible
    ksBtn.Text = keystrokeUI.Visible and "⌨️ KEYSTROKES: ON ✅" or "⌨️ KEYSTROKES: OFF"
    ksBtn.BackgroundColor3 = keystrokeUI.Visible and THEME.Success or THEME.Secondary
end)

-- Tab switching
scriptsTabBtn.MouseButton1Click:Connect(function()
    scriptsPanel.Visible = true; settingsPanel.Visible = false
    scriptsTabBtn.BackgroundColor3 = THEME.Primary; scriptsTabBtn.TextColor3 = THEME.Background
    settingsTabBtn.BackgroundColor3 = THEME.SurfaceLight; settingsTabBtn.TextColor3 = THEME.Text
end)
settingsTabBtn.MouseButton1Click:Connect(function()
    scriptsPanel.Visible = false; settingsPanel.Visible = true
    settingsTabBtn.BackgroundColor3 = THEME.Primary; settingsTabBtn.TextColor3 = THEME.Background
    scriptsTabBtn.BackgroundColor3 = THEME.SurfaceLight; scriptsTabBtn.TextColor3 = THEME.Text
end)

makeDraggable(mainUI, header)
