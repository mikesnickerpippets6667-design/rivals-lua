--  VOID TAB
-- ═══════════════════════════════════════════
local vPage=tabPages["Void"]

local voidBigBtn=Instance.new("TextButton",vPage)
voidBigBtn.Size=UDim2.new(1,-16,0,52); voidBigBtn.BackgroundColor3=Color3.fromRGB(20,10,35)
voidBigBtn.Text="VOID SPAM  OFF"; voidBigBtn.TextColor3=T.Sub; voidBigBtn.Font=Enum.Font.GothamBold
voidBigBtn.TextSize=16; voidBigBtn.AutoButtonColor=false; voidBigBtn.BorderSizePixel=0; voidBigBtn.LayoutOrder=1
mkCorner(12,voidBigBtn); local vBtnStroke=mkStroke(Color3.fromRGB(40,20,80),2,voidBigBtn)
mkGrad(Color3.fromRGB(18,10,32),Color3.fromRGB(10,6,20),120,voidBigBtn)

local function refreshVoidBtn(on)
    if on then
        TweenService:Create(voidBigBtn,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(30,0,60)}):Play()
        TweenService:Create(vBtnStroke,TweenInfo.new(0.2),{Color=T.Danger}):Play()
        voidBigBtn.Text="VOID SPAM  ON"; voidBigBtn.TextColor3=T.Danger
    else
        TweenService:Create(voidBigBtn,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(20,10,35)}):Play()
        TweenService:Create(vBtnStroke,TweenInfo.new(0.2),{Color=Color3.fromRGB(40,20,80)}):Play()
        voidBigBtn.Text="VOID SPAM  OFF"; voidBigBtn.TextColor3=T.Sub
    end
end

