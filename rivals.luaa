addGlow(voidBtn, THEME.Danger)

local orbitBtn   = makeToggleBtn("🐚 ORBIT: OFF  [O]", THEME.Warning, 55)

-- Orbit erratic toggle
local erraticRow = Instance.new("Frame")
erraticRow.Size = UDim2.new(1,0,0,30)
erraticRow.BackgroundColor3 = THEME.Surface
erraticRow.Parent = settingsPanel
addCorner(erraticRow, 10)
local erraticLbl = Instance.new("TextLabel")
