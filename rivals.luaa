content.Size = UDim2.new(1,-30,1,-118)
content.Position = UDim2.fromOffset(15,110)
content.BackgroundTransparency = 1
content.Parent = mainUI

-- SCRIPTS PANEL
local scriptsPanel = Instance.new("Frame")
scriptsPanel.Size = UDim2.new(1,0,1,0)
scriptsPanel.BackgroundTransparency = 1
scriptsPanel.Visible = true
scriptsPanel.Parent = content

local searchBox = Instance.new("TextBox")
searchBox.Size = UDim2.new(1,0,0,35)
searchBox.BackgroundColor3 = THEME.Surface
searchBox.Text = ""
searchBox.PlaceholderText = "🔍 Search scripts..."
searchBox.TextColor3 = THEME.Text
searchBox.PlaceholderColor3 = THEME.TextDim
searchBox.Font = Enum.Font.Gotham
searchBox.TextSize = 13
searchBox.Parent = scriptsPanel
addCorner(searchBox, 8)
addStroke(searchBox, THEME.SurfaceLight)

local scrollFrame = Instance.new("ScrollingFrame")
scrollFrame.Size = UDim2.new(1,0,1,-45)
scrollFrame.Position = UDim2.fromOffset(0,45)
scrollFrame.BackgroundColor3 = THEME.Surface
scrollFrame.BorderSizePixel = 0
scrollFrame.ScrollBarThickness = 5
scrollFrame.ScrollBarImageColor3 = THEME.Primary
scrollFrame.Parent = scriptsPanel
addCorner(scrollFrame, 12)
local listLayout = Instance.new("UIListLayout")
listLayout.Padding = UDim.new(0,8)
listLayout.Parent = scrollFrame

local function populateScripts(filter)
    for _, c in ipairs(scrollFrame:GetChildren()) do
        if c:IsA("Frame") then c:Destroy() end
    end
    local count = 0
    for _, sd in ipairs(ScriptLibrary) do
        if filter == "" or sd.name:lower():find(filter:lower()) or sd.game:lower():find(filter:lower()) then
            count = count + 1
            local card = Instance.new("Frame")
            card.Size = UDim2.new(1,-10,0,70)
            card.BackgroundColor3 = THEME.SurfaceLight
            card.Parent = scrollFrame
            addCorner(card, 10)
            local cs = addStroke(card, THEME.Primary, 1); cs.Transparency = 0.6

            local nm = Instance.new("TextLabel")
            nm.Size = UDim2.new(1,-80,0,22); nm.Position = UDim2.fromOffset(10,8)
            nm.BackgroundTransparency = 1; nm.Text = sd.name
            nm.TextColor3 = THEME.Primary; nm.Font = Enum.Font.GothamBold
            nm.TextSize = 15; nm.TextXAlignment = Enum.TextXAlignment.Left
            nm.Parent = card

            local gm = Instance.new("TextLabel")
            gm.Size = UDim2.new(0.55,-10,0,18); gm.Position = UDim2.fromOffset(10,32)
            gm.BackgroundTransparency = 1; gm.Text = "🎮 "..sd.game
            gm.TextColor3 = THEME.Text; gm.Font = Enum.Font.Gotham
            gm.TextSize = 11; gm.TextXAlignment = Enum.TextXAlignment.Left
            gm.Parent = card

            local tp = Instance.new("TextLabel")
            tp.Size = UDim2.new(0.3,0,0,18); tp.Position = UDim2.new(0.65,0,0,32)
            tp.BackgroundTransparency = 1
            tp.Text = sd.type == "Keyless" and "✅ Keyless" or "🔑 Key"
            tp.TextColor3 = sd.type == "Keyless" and THEME.Success or THEME.Warning
            tp.Font = Enum.Font.GothamBold; tp.TextSize = 11
            tp.TextXAlignment = Enum.TextXAlignment.Right
            tp.Parent = card

            local ft = Instance.new("TextLabel")
            ft.Size = UDim2.new(1,-80,0,16); ft.Position = UDim2.fromOffset(10,50)
            ft.BackgroundTransparency = 1; ft.Text = sd.features
            ft.TextColor3 = THEME.TextDim; ft.Font = Enum.Font.Gotham
            ft.TextSize = 10; ft.TextXAlignment = Enum.TextXAlignment.Left
            ft.TextTruncate = Enum.TextTruncate.AtEnd
            ft.Parent = card

            local eb = Instance.new("TextButton")
            eb.Size = UDim2.fromOffset(60,50); eb.Position = UDim2.new(1,-70,0.5,-25)
            eb.BackgroundColor3 = THEME.Success; eb.Text = "▶"
            eb.TextColor3 = THEME.Text; eb.Font = Enum.Font.GothamBlack
            eb.TextSize = 20; eb.Parent = card
            addCorner(eb, 8)
            wireButton(eb, THEME.Success)

            eb.MouseButton1Click:Connect(function()
                pcall(function()
                    local fn = loadstring(sd.code)
                    if fn then fn() end
                end)
            end)

            card.MouseEnter:Connect(function() TweenService:Create(card,TweenInfo.new(0.15),{BackgroundColor3=THEME.Surface}):Play() end)
            card.MouseLeave:Connect(function() TweenService:Create(card,TweenInfo.new(0.15),{BackgroundColor3=THEME.SurfaceLight}):Play() end)
        end
    end
    scrollFrame.CanvasSize = UDim2.new(0,0,0,count*78)
end
searchBox:GetPropertyChangedSignal("Text"):Connect(function() populateScripts(searchBox.Text) end)
populateScripts("")

-- SETTINGS PANEL
local settingsPanel = Instance.new("Frame")
settingsPanel.Size = UDim2.new(1,0,1,0)
settingsPanel.BackgroundTransparency = 1
settingsPanel.Visible = false
settingsPanel.Parent = content

local sLayout = Instance.new("UIListLayout")
sLayout.Padding = UDim.new(0,10)
sLayout.Parent = settingsPanel

local statusLabel = Instance.new("TextLabel")

local function makeToggleBtn(text, onColor, size)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1,0,0,size or 55)
    btn.BackgroundColor3 = onColor
    btn.Text = text
    btn.TextColor3 = THEME.Text
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 16
    btn.Parent = settingsPanel
    addCorner(btn, 12)
    addStroke(btn, onColor, 2)
    wireButton(btn, onColor)
    return btn
end

-- Voidspam mode selector row
local modeRow = Instance.new("Frame")
modeRow.Size = UDim2.new(1,0,0,36)
modeRow.BackgroundColor3 = THEME.Surface
modeRow.Parent = settingsPanel
addCorner(modeRow, 10)
local modeLabel = Instance.new("TextLabel")
modeLabel.Size = UDim2.new(0.38,0,1,0); modeLabel.Position = UDim2.fromOffset(10,0)
modeLabel.BackgroundTransparency = 1; modeLabel.Text = "VS MODE:"
modeLabel.TextColor3 = THEME.TextDim; modeLabel.Font = Enum.Font.GothamBold; modeLabel.TextSize = 12
modeLabel.TextXAlignment = Enum.TextXAlignment.Left; modeLabel.Parent = modeRow
local modes = {"combat","blink","chaos"}
local modeBtns = {}
local modeX = 0.38
for _, m in ipairs(modes) do
    local mb = Instance.new("TextButton")
    mb.Size = UDim2.new(0.2,0,0,26); mb.Position = UDim2.new(modeX,0,0.5,-13)
    mb.BackgroundColor3 = CONFIG.VOIDSPAM_MODE == m and THEME.Primary or THEME.SurfaceLight
    mb.Text = m:upper(); mb.TextColor3 = THEME.Background; mb.Font = Enum.Font.GothamBold; mb.TextSize = 10
    mb.Parent = modeRow; addCorner(mb,6)
    modeBtns[m] = mb
    modeX = modeX + 0.205
    mb.MouseButton1Click:Connect(function()
        CONFIG.VOIDSPAM_MODE = m
        for k,b in pairs(modeBtns) do
            b.BackgroundColor3 = k == m and THEME.Primary or THEME.SurfaceLight
        end
        if voidspamming then stopVoidspam(); startVoidspam() end
    end)
end

