tabBar.BackgroundTransparency=1
local tabLayout=Instance.new("UIListLayout",tabBar); tabLayout.FillDirection=Enum.FillDirection.Horizontal; tabLayout.Padding=UDim.new(0,3)

local tabPages={} local tabBtns={}
local TAB_NAMES={"Void","Defense","Anti-Aim","Config"}
local TAB_COLORS={Void=T.Accent,Defense=T.On,["Anti-Aim"]=T.AA,Config=T.Cfg}

for _,name in ipairs(TAB_NAMES) do
    local btn=Instance.new("TextButton",tabBar); btn.Size=UDim2.new(0,68,1,0)
    btn.BackgroundColor3=T.Surface; btn.Text=name=="Anti-Aim" and "A-Aim" or name
    btn.TextColor3=T.Sub; btn.Font=Enum.Font.GothamSemibold; btn.TextSize=10
    btn.AutoButtonColor=false; btn.BorderSizePixel=0; mkCorner(6,btn); tabBtns[name]=btn
    local page=Instance.new("ScrollingFrame",panel); page.Size=UDim2.new(1,0,1,-82); page.Position=UDim2.new(0,0,0,82)
    page.BackgroundTransparency=1; page.BorderSizePixel=0; page.ScrollBarThickness=2
    page.ScrollBarImageColor3=T.Accent; page.CanvasSize=UDim2.new(0,0,0,0)
    page.ScrollingDirection=Enum.ScrollingDirection.Y; page.Visible=false
    tabPages[name]=page; setupList(page)
end

local function switchTab(name)
    for k,b in pairs(tabBtns) do
        local active=k==name; local col=TAB_COLORS[k] or T.Accent
        TweenService:Create(b,TweenInfo.new(0.15),{BackgroundColor3=active and col or T.Surface, TextColor3=active and Color3.fromRGB(255,255,255) or T.Sub}):Play()
        tabPages[k].Visible=active
    end
end
for _,name in ipairs(TAB_NAMES) do tabBtns[name].MouseButton1Click:Connect(function() switchTab(name) end) end
switchTab("Void")

