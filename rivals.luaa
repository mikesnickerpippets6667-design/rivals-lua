--  CONFIG TAB
-- ═══════════════════════════════════════════
local cPage=tabPages["Config"]

-- ─── Multi-config storage ─────────────────────────────────────────────────
-- File stores: { configs = { {_name="...", ghostStep=bool, ...}, ... } }
local CONFIGS_FILE = "brays_v5_configs.json"

local function loadAllConfigs()
    if not (isfile and readfile and isfile(CONFIGS_FILE)) then return {} end
    local ok,data=pcall(function() return HttpService:JSONDecode(readfile(CONFIGS_FILE)) end)
    if ok and data and data.configs then return data.configs end
    return {}
end

local function saveAllConfigs(list)
    if not writefile then return false end
    pcall(function() writefile(CONFIGS_FILE, HttpService:JSONEncode({configs=list})) end)
    return true
end

local function snapshotCfg(name)
    return {
        _name       = name,
        ghostStep   = cfg.ghostStep,
        ghostInt    = getGhostInt(),
        offsetInt   = getOffInt(),
        velClamp    = cfg.velClamp,
        predBreaker = cfg.predBreaker,
        predInt     = getPredInt(),
        frameNoise  = cfg.frameNoise,
        noiseAmt    = getNoiseAmt(),
        srcShield   = cfg.srcShield,
        aaEnabled   = cfg.aaEnabled,
        aaMode      = getAAMode(),
        spinSpeed   = getSpinSpd(),
        partMerge   = cfg.partMerge,
    }
end

local function applyConfig(data)
    if not data then return end
    if data.ghostStep   ~= nil then setGhostSt(data.ghostStep,   false); cfg.ghostStep=data.ghostStep     end
    if data.velClamp    ~= nil then setVelSt(data.velClamp,      false); cfg.velClamp=data.velClamp       end
    if data.predBreaker ~= nil then setPredSt(data.predBreaker,  false); cfg.predBreaker=data.predBreaker  end
    if data.frameNoise  ~= nil then setNoiseSt(data.frameNoise,  false); cfg.frameNoise=data.frameNoise   end
    if data.srcShield   ~= nil then setShieldSt(data.srcShield,  false); cfg.srcShield=data.srcShield     end
    if data.aaEnabled   ~= nil then setAASt(data.aaEnabled,      false); cfg.aaEnabled=data.aaEnabled     end
    if data.partMerge   ~= nil then setPMSt(data.partMerge,      false); cfg.partMerge=data.partMerge     end
    if data.ghostInt    then setGhostInt(data.ghostInt);  cfg.ghostInt=data.ghostInt   end
    if data.offsetInt   then setOffInt(data.offsetInt);   cfg.offsetInt=data.offsetInt  end
    if data.predInt     then setPredInt(data.predInt);    cfg.predInt=data.predInt     end
    if data.noiseAmt    then setNoiseAmt(data.noiseAmt);  cfg.noiseAmt=data.noiseAmt   end
    if data.spinSpeed   then setSpinSpd(data.spinSpeed);  cfg.spinSpeed=data.spinSpeed  end
    if data.aaMode      then setAAMode(data.aaMode,false);cfg.aaMode=data.aaMode       end
end

-- ─── UI ───────────────────────────────────────────────────────────────────
mkSecLbl(cPage,"  SAVE CONFIG",1)

-- Name input row
local nameRow=Instance.new("Frame",cPage); nameRow.Size=UDim2.new(1,-16,0,38)
nameRow.BackgroundColor3=T.Surface; nameRow.BorderSizePixel=0; nameRow.LayoutOrder=2; mkCorner(8,nameRow)
local nameLbl2=Instance.new("TextLabel",nameRow); nameLbl2.Size=UDim2.new(0.38,0,1,0); nameLbl2.Position=UDim2.new(0,12,0,0)
nameRow.BackgroundTransparency=0
nameLbl2.BackgroundTransparency=1; nameLbl2.Text="Name"; nameLbl2.TextColor3=T.Sub
nameLbl2.Font=Enum.Font.Gotham; nameLbl2.TextSize=11; nameLbl2.TextXAlignment=Enum.TextXAlignment.Left
local nameBox=Instance.new("TextBox",nameRow); nameBox.Size=UDim2.new(0.58,0,0,24); nameBox.Position=UDim2.new(0.40,0,0.5,-12)
nameBox.BackgroundColor3=Color3.fromRGB(22,28,48); nameBox.Text="default"; nameBox.TextColor3=T.Text
nameBox.PlaceholderText="config name..."; nameBox.Font=Enum.Font.Gotham; nameBox.TextSize=11
nameBox.BorderSizePixel=0; nameBox.ClearTextOnFocus=false; mkCorner(6,nameBox); mkStroke(T.Cfg,1,nameBox)

-- configList forward-declared so SAVE can call it
local refreshList

-- SAVE button
mkActionBtn(cPage,"Save Current Settings",3,"SAVE",T.Cfg,function(btn,flash)
    if not writefile then flash("No writefile",T.Danger); return end
    local name=nameBox.Text
    if name=="" then name="config" end
    local list=loadAllConfigs()
    -- overwrite if name already exists
    local found=false
    for i,c in ipairs(list) do
        if c._name==name then list[i]=snapshotCfg(name); found=true; break end
    end
    if not found then table.insert(list,snapshotCfg(name)) end
    saveAllConfigs(list)
    if refreshList then refreshList(list) end
    flash("Saved!",T.On)
end)

-- RESET button
mkActionBtn(cPage,"Reset All to Default",4,"RESET",T.Danger,function(btn,flash)
    if cfg.voidActive  then stopVoid(); refreshVoidBtn(false) end
    if cfg.orbitActive then stopOrbit(); setOrbitSt(false,true) end
    setGhostSt(false,false); setVelSt(false,false); setPredSt(false,false)
    setNoiseSt(false,false); setShieldSt(false,false)
    setGhostInt(7); setOffInt(0); setPredInt(0); setNoiseAmt(0)
    setAASt(false,false); setPMSt(false,false); setSpinSpd(10); setAAMode("SPIN",false)
    flash("Reset!",T.On)
end)

-- ─── Config List ──────────────────────────────────────────────────────────
mkSecLbl(cPage,"  SAVED CONFIGS",5)

-- Container card that holds the list
local listCard=Instance.new("Frame",cPage)
listCard.Size=UDim2.new(1,-16,0,200); listCard.BackgroundColor3=Color3.fromRGB(12,15,26)
listCard.BorderSizePixel=0; listCard.LayoutOrder=6; listCard.ClipsDescendants=true
mkCorner(10,listCard); mkStroke(T.Stroke,1,listCard)

-- Inner scroll
local listScroll=Instance.new("ScrollingFrame",listCard)
listScroll.Size=UDim2.new(1,0,1,0); listScroll.BackgroundTransparency=1
listScroll.BorderSizePixel=0; listScroll.ScrollBarThickness=3
listScroll.ScrollBarImageColor3=T.Cfg; listScroll.CanvasSize=UDim2.new(0,0,0,0)
listScroll.ScrollingDirection=Enum.ScrollingDirection.Y
local listLayout=Instance.new("UIListLayout",listScroll)
listLayout.Padding=UDim.new(0,3); listLayout.SortOrder=Enum.SortOrder.LayoutOrder
listLayout.HorizontalAlignment=Enum.HorizontalAlignment.Center
local listPad=Instance.new("UIPadding",listScroll); listPad.PaddingTop=UDim.new(0,4)
listLayout.Changed:Connect(function()
    listScroll.CanvasSize=UDim2.new(0,0,0,listLayout.AbsoluteContentSize.Y+8)
end)

-- Empty state label
local emptyLbl=Instance.new("TextLabel",listScroll)
emptyLbl.Size=UDim2.new(1,-10,0,50); emptyLbl.BackgroundTransparency=1
emptyLbl.Text="No configs saved yet.\nSave one above!"; emptyLbl.TextColor3=T.Sub
emptyLbl.Font=Enum.Font.Gotham; emptyLbl.TextSize=11; emptyLbl.TextWrapped=true
emptyLbl.LayoutOrder=0

-- Build one config row
local function buildRow(list, entry, order)
    local row=Instance.new("Frame",listScroll)
    row.Size=UDim2.new(1,-8,0,42); row.BackgroundColor3=T.Surface
    row.BorderSizePixel=0; row.LayoutOrder=order; mkCorner(8,row)
    mkStroke(Color3.fromRGB(50,60,100),1,row)

    -- Config name
    local nameLbl=Instance.new("TextLabel",row); nameLbl.Size=UDim2.new(1,-110,0,20)
    nameLbl.Position=UDim2.new(0,10,0,4); nameLbl.BackgroundTransparency=1
    nameLbl.Text=entry._name or "unnamed"; nameLbl.TextColor3=T.Text
    nameLbl.Font=Enum.Font.GothamBold; nameLbl.TextSize=12; nameLbl.TextXAlignment=Enum.TextXAlignment.Left
    nameLbl.TextTruncate=Enum.TextTruncate.AtEnd

    -- Feature summary line (shows what's ON)
    local flags={}
    if entry.ghostStep  then table.insert(flags,"Ghost")  end
    if entry.velClamp   then table.insert(flags,"Vel")    end
    if entry.predBreaker then table.insert(flags,"Pred")  end
    if entry.frameNoise then table.insert(flags,"Noise")  end
    if entry.aaEnabled  then table.insert(flags,"AA")     end
    if entry.partMerge  then table.insert(flags,"Merge")  end
    local summaryTxt = #flags>0 and table.concat(flags," ") or "all off"
    local summaryLbl=Instance.new("TextLabel",row); summaryLbl.Size=UDim2.new(1,-110,0,14)
    summaryLbl.Position=UDim2.new(0,10,0,24); summaryLbl.BackgroundTransparency=1
    summaryLbl.Text=summaryTxt; summaryLbl.TextColor3=T.Sub
    summaryLbl.Font=Enum.Font.Gotham; summaryLbl.TextSize=9; summaryLbl.TextXAlignment=Enum.TextXAlignment.Left
    summaryLbl.TextTruncate=Enum.TextTruncate.AtEnd

    -- LOAD button
    local loadBtn=Instance.new("TextButton",row); loadBtn.Size=UDim2.fromOffset(44,26)
    loadBtn.Position=UDim2.new(1,-98,0.5,-13); loadBtn.BackgroundColor3=T.Accent
    loadBtn.Text="LOAD"; loadBtn.TextColor3=Color3.fromRGB(255,255,255)
    loadBtn.Font=Enum.Font.GothamBold; loadBtn.TextSize=10; loadBtn.AutoButtonColor=false
    mkCorner(6,loadBtn)
    loadBtn.MouseButton1Click:Connect(function()
        applyConfig(entry)
        nameBox.Text=entry._name or "unnamed"
        -- Flash row green briefly
        TweenService:Create(row,TweenInfo.new(0.15),{BackgroundColor3=Color3.fromRGB(0,60,40)}):Play()
        task.delay(0.5,function() TweenService:Create(row,TweenInfo.new(0.3),{BackgroundColor3=T.Surface}):Play() end)
        TweenService:Create(loadBtn,TweenInfo.new(0.1),{BackgroundColor3=T.On}):Play()
        loadBtn.Text="OK!"
        task.delay(1.5,function()
            if loadBtn and loadBtn.Parent then
                TweenService:Create(loadBtn,TweenInfo.new(0.2),{BackgroundColor3=T.Accent}):Play()
                loadBtn.Text="LOAD"
            end
        end)
    end)

    -- DEL button
    local delBtn=Instance.new("TextButton",row); delBtn.Size=UDim2.fromOffset(44,26)
    delBtn.Position=UDim2.new(1,-50,0.5,-13); delBtn.BackgroundColor3=Color3.fromRGB(60,20,28)
    delBtn.Text="DEL"; delBtn.TextColor3=T.Danger
    delBtn.Font=Enum.Font.GothamBold; delBtn.TextSize=10; delBtn.AutoButtonColor=false
    mkCorner(6,delBtn); mkStroke(T.Danger,1,delBtn)
    delBtn.MouseButton1Click:Connect(function()
        -- Remove from list and re-save
        for i,c in ipairs(list) do
            if c._name==entry._name then table.remove(list,i); break end
        end
        saveAllConfigs(list)
        if refreshList then refreshList(list) end
    end)

    return row
end

-- Refresh function — clears and rebuilds the list
refreshList=function(list)
    -- Destroy all existing rows (keep emptyLbl)
    for _,child in ipairs(listScroll:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
    if #list==0 then
        emptyLbl.Visible=true
    else
        emptyLbl.Visible=false
        for i,entry in ipairs(list) do
            buildRow(list,entry,i)
        end
    end
end

-- Initial load on script start
refreshList(loadAllConfigs())

-- ─── Active Flags ─────────────────────────────────────────────────────────
mkSecLbl(cPage,"  ACTIVE FLAGS",7)

local function mkFlag(page, label, order, getStateFn, onColor)
    local row=Instance.new("Frame",page); row.Size=UDim2.new(1,-16,0,26); row.BackgroundColor3=T.Surface
    row.BorderSizePixel=0; row.LayoutOrder=order; mkCorner(7,row)
    local lbl=Instance.new("TextLabel",row); lbl.Size=UDim2.new(0.65,0,1,0); lbl.Position=UDim2.new(0,12,0,0)
    lbl.BackgroundTransparency=1; lbl.Text=label; lbl.TextColor3=T.Sub; lbl.Font=Enum.Font.Gotham; lbl.TextSize=11; lbl.TextXAlignment=Enum.TextXAlignment.Left
    local dot=Instance.new("Frame",row); dot.Size=UDim2.fromOffset(8,8); dot.Position=UDim2.new(1,-18,0.5,-4)
    dot.BackgroundColor3=T.Off; dot.BorderSizePixel=0; mkCorner(4,dot)
    local vtxt=Instance.new("TextLabel",row); vtxt.Size=UDim2.new(0.3,0,1,0); vtxt.Position=UDim2.new(0.66,0,0,0)
    vtxt.BackgroundTransparency=1; vtxt.Text="OFF"; vtxt.TextColor3=T.Sub; vtxt.Font=Enum.Font.GothamBold; vtxt.TextSize=11; vtxt.TextXAlignment=Enum.TextXAlignment.Right
    RunService.Heartbeat:Connect(function()
        if not (dot and dot.Parent) then return end
        local on=getStateFn()
        dot.BackgroundColor3=on and (onColor or T.On) or T.Off
        vtxt.Text=on and "ON" or "OFF"; vtxt.TextColor3=on and (onColor or T.On) or T.Sub
    end)
end

mkFlag(cPage,"Void Spam",8,     function() return cfg.voidActive end,   T.Danger)
mkFlag(cPage,"Orbit",9,         function() return cfg.orbitActive end,   T.Accent)
mkFlag(cPage,"Ghost Step",10,   function() return cfg.ghostStep end,     T.On)
mkFlag(cPage,"Velocity Clamp",11,function() return cfg.velClamp end,    T.On)
mkFlag(cPage,"Pred Breaker",12, function() return cfg.predBreaker end,   T.On)
mkFlag(cPage,"Frame Noise",13,  function() return cfg.frameNoise end,    T.On)
mkFlag(cPage,"Anti-Aim",14,     function() return cfg.aaEnabled end,     T.AA)
mkFlag(cPage,"Part Merge",15,   function() return cfg.partMerge end,     T.AA)

mkSecLbl(cPage,"  INFO",16)
local _,execValLbl=mkInfoRow(cPage,"Executor",17,T.Cfg)
pcall(function() execValLbl.Text=identifyexecutor and identifyexecutor() or "Unknown" end)
local _,verValLbl=mkInfoRow(cPage,"Version",18,T.Accent)
verValLbl.Text="v5.0"

-- ═══════════════════════════════════════════
--  MAIN HEARTBEAT (defense + anti-aim + part merge)
-- ═══════════════════════════════════════════
RunService.Heartbeat:Connect(function()
    local c=getChar(); if not c then return end
    local hrp=c:FindFirstChild("HumanoidRootPart"); if not hrp then return end

    -- Ghost Step
    if cfg.ghostStep then
        local g=cfg.ghostInt*0.01
        hrp.CFrame=hrp.CFrame*CFrame.new((math.random()-.5)*g,0,(math.random()-.5)*g)
    end
    -- Velocity Clamp
    if cfg.velClamp then
        local v=hrp.AssemblyLinearVelocity; local cap=50
        hrp.AssemblyLinearVelocity=Vector3.new(math.clamp(v.X,-cap,cap),v.Y,math.clamp(v.Z,-cap,cap))
    end
    -- Frame Noise
    if cfg.frameNoise then
        local n=cfg.noiseAmt*0.005
        hrp.CFrame=hrp.CFrame*CFrame.Angles((math.random()-.5)*n,(math.random()-.5)*n,(math.random()-.5)*n)
    end
    -- Prediction Breaker
    if cfg.predBreaker then
        local p2=cfg.predInt*0.02
        hrp.CFrame=hrp.CFrame+Vector3.new((math.random()-.5)*p2,0,(math.random()-.5)*p2)
    end

    -- ── ANTI-AIM ──
    if cfg.aaEnabled then
        local spd=cfg.spinSpeed; local m=cfg.aaMode
        if m=="SPIN"    then hrp.CFrame=hrp.CFrame*CFrame.Angles(0,math.rad(spd),0)
        elseif m=="JITTER"  then hrp.CFrame=hrp.CFrame*CFrame.Angles(0,math.rad(math.random(0,1)==0 and 180 or -180),0)
        elseif m=="FLIP"    then hrp.CFrame=hrp.CFrame*CFrame.Angles(math.rad(-spd),math.rad(180),0)
        elseif m=="STRAFE"  then hrp.CFrame=hrp.CFrame*CFrame.Angles(0,math.rad(math.sin(tick()*5)*90),0)
        elseif m=="DESYNC"  then hrp.CFrame=hrp.CFrame*CFrame.Angles(0,math.rad((math.random()-.5)*180+math.sin(tick()*3)*60),0)
        elseif m=="FREEFORM" then hrp.CFrame=hrp.CFrame*CFrame.Angles(math.rad((math.random()-.5)*180),math.rad((math.random()-.5)*180),math.rad((math.random()-.5)*180))
        elseif m=="MICRO"   then hrp.CFrame=hrp.CFrame*CFrame.Angles(0,math.rad((math.random()-.5)*8),0)
        end
    end

    -- ── PART MERGE ──
    -- Collapses every BasePart into the HRP position each frame
    -- Server receives a character where all parts overlap at one point
    if cfg.partMerge then
        local jitter=getMergeJitter()
        for _,p in ipairs(c:GetDescendants()) do
            if p:IsA("BasePart") and p~=hrp then
                pcall(function()
                    local j=Vector3.new((math.random()-.5)*jitter,(math.random()-.5)*jitter,(math.random()-.5)*jitter)
                    p.CFrame=CFrame.new(hrp.Position+j)*hrp.CFrame.Rotation
                    p.AssemblyLinearVelocity=hrp.AssemblyLinearVelocity
                end)
            end
        end
    end
end)

-- ═══════════════════════════════════════════
--  PANEL TOGGLE
-- ═══════════════════════════════════════════
local panelOpen=false
local function togglePanel()
    panelOpen=not panelOpen; panel.Visible=panelOpen
    TweenService:Create(openBtn,TweenInfo.new(0.18),{BackgroundColor3=panelOpen and Color3.fromRGB(60,220,255) or T.Accent}):Play()
end
openBtn.MouseButton1Click:Connect(togglePanel)
openBtn.TouchTap:Connect(togglePanel)

-- ═══════════════════════════════════════════
--  KEYBINDS
-- ═══════════════════════════════════════════
UserInputService.InputBegan:Connect(function(input,gp)
    if gp then return end
    if     input.KeyCode==Enum.KeyCode.P          then toggleVoid()
    elseif input.KeyCode==Enum.KeyCode.O          then local s=not cfg.orbitActive; setOrbitSt(s,false)
    elseif input.KeyCode==Enum.KeyCode.RightShift then togglePanel()
    end
end)

-- ═══════════════════════════════════════════
--  DRAG
-- ═══════════════════════════════════════════
local dragActive,dragStart,dragStartPos=false,nil,nil
header.InputBegan:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
        dragActive=true; dragStart=i.Position; dragStartPos=panel.Position
    end
end)
UserInputService.InputChanged:Connect(function(i)
    if not dragActive then return end
    if i.UserInputType~=Enum.UserInputType.MouseMovement and i.UserInputType~=Enum.UserInputType.Touch then return end
    local d=i.Position-dragStart
    panel.Position=UDim2.fromOffset(dragStartPos.X.Offset+d.X,dragStartPos.Y.Offset+d.Y)
end)
UserInputService.InputEnded:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then dragActive=false end
end)
local obDrag,obDragStart,obDragStartPos=false,nil,nil
openBtn.InputBegan:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
        obDrag=true; obDragStart=i.Position; obDragStartPos=openBtn.Position
    end
end)
UserInputService.InputChanged:Connect(function(i)
    if not obDrag then return end
    if i.UserInputType~=Enum.UserInputType.MouseMovement and i.UserInputType~=Enum.UserInputType.Touch then return end
    local d=i.Position-obDragStart
    if math.abs(d.X)>4 or math.abs(d.Y)>4 then
        openBtn.Position=UDim2.new(obDragStartPos.X.Scale,obDragStartPos.X.Offset+d.X,obDragStartPos.Y.Scale,obDragStartPos.Y.Offset+d.Y)
    end
end)
UserInputService.InputEnded:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then obDrag=false end
end)

print("[Brays Lua v5.0] Loaded | Void[P] Orbit[O] UI[RightShift]")
