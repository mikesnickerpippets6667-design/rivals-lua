    local settingsTab = Instance.new("TextButton")
    settingsTab.Size = UDim2.new(0.5, -5, 1, 0)
    settingsTab.BackgroundColor3 = THEME.SurfaceLight
    settingsTab.Text = "⚙️ SETTINGS"
    settingsTab.TextColor3 = THEME.Text
    settingsTab.Font = Enum.Font.GothamBold
    settingsTab.TextSize = 14
    settingsTab.Parent = tabContainer
    addCorner(settingsTab, 8)
    
    -- Content container
