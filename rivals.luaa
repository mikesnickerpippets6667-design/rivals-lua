-- Tabs
local tabContainer = Instance.new("Frame")
tabContainer.Size = UDim2.new(1,-40,0,38)
tabContainer.Position = UDim2.fromOffset(20,63)
tabContainer.BackgroundTransparency = 1
tabContainer.Parent = header
local tabLayout = Instance.new("UIListLayout")
tabLayout.FillDirection = Enum.FillDirection.Horizontal
tabLayout.Padding = UDim.new(0,8)
tabLayout.Parent = tabContainer

local function makeTab(text, active)
    local t = Instance.new("TextButton")
    t.Size = UDim2.new(0.5,-4,1,0)
    t.BackgroundColor3 = active and THEME.Primary or THEME.SurfaceLight
    t.Text = text
    t.TextColor3 = active and THEME.Background or THEME.Text
    t.Font = Enum.Font.GothamBold
    t.TextSize = 13
    t.Parent = tabContainer
    addCorner(t, 8)
    return t
end
local scriptsTabBtn  = makeTab("📜 SCRIPTS", true)
local settingsTabBtn = makeTab("⚙️ SETTINGS", false)

-- Content area
